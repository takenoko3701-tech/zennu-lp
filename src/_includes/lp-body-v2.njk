<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ site.meta.title }}</title>
  <meta name="description" content="{{ site.meta.description }}">
  <link rel="canonical" href="{{ site.meta.url }}/2/">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <meta name="robots" content="noindex, follow">

  <!-- Open Graph / SNSシェア -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="ZenNu WELLNESS DESIGN">
  <meta property="og:title" content="{{ site.meta.title }}">
  <meta property="og:description" content="{{ site.meta.description }}">
  <meta property="og:url" content="{{ site.meta.url }}/2/">
  <meta property="og:image" content="{{ site.meta.url }}{{ site.meta.ogImage }}">
  <meta property="og:locale" content="ja_JP">
  <meta name="twitter:card" content="summary_large_image">

  <!-- 構造化データ（ローカルビジネス / ジム） -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HealthClub",
    "name": "ZenNu WELLNESS DESIGN",
    "description": "{{ site.meta.description }}",
    "url": "{{ site.meta.url }}/",
    "image": "{{ site.meta.url }}{{ site.meta.ogImage }}",
    "telephone": "{{ site.contact.telDisplay }}",
    "priceRange": "¥¥",
    "address": {
      "@type": "PostalAddress",
      "postalCode": "860-0845",
      "addressRegion": "熊本県",
      "addressLocality": "熊本市中央区",
      "streetAddress": "上通町6-15 オークス第二ビル 2F",
      "addressCountry": "JP"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "{{ site.meta.lat }}",
      "longitude": "{{ site.meta.lng }}"
    },
    "openingHoursSpecification": [{
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "07:00",
      "closes": "22:00"
    }]
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800;900&family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
  {% include "site-style.njk" %}
  <style>
    /* /2/ only: diet-first appeal variant */
    .site-header:not(.scrolled) .logo-img { filter: none; }
    .site-header:not(.scrolled) .site-nav a { color: rgba(45,38,33,.78); }
    .site-header:not(.scrolled) .site-nav a:hover { color: var(--orange); background: rgba(232,112,48,.08); }
    .site-header:not(.scrolled) .ham-btn span { background: #2d2621; }
    .v2-hero {
      position: relative;
      min-height: 760px;
      padding: 64px 0 56px;
      overflow: hidden;
      background: linear-gradient(135deg, #fff 0%, #fffaf6 58%, #f5e5d9 100%);
      color: var(--text);
    }
    .v2-hero::after {
      content: '';
      position: absolute;
      inset: auto -10% -42% auto;
      width: 54vw;
      height: 54vw;
      border: 1px solid rgba(232,112,48,.2);
      border-radius: 50%;
      box-shadow: 0 0 0 70px rgba(232,112,48,.035), 0 0 0 140px rgba(232,112,48,.018);
      pointer-events: none;
    }
    .v2-hero-photo {
      position: absolute;
      inset: 86px 0 0 49%;
      overflow: hidden;
      border-radius: 36px 0 0 0;
      box-shadow: -18px 22px 60px rgba(78,55,40,.1);
    }
    .v2-hero-photo::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        linear-gradient(90deg, #fffaf6 0%, rgba(255,250,246,.84) 16%, rgba(255,250,246,.08) 54%),
        linear-gradient(0deg, rgba(255,250,246,.92) 0%, rgba(255,250,246,0) 34%);
    }
    .v2-hero-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(.9) contrast(1.02) brightness(1.04);
    }
    .v2-hero-inner {
      position: relative;
      z-index: 2;
      width: min(1200px, 100%);
      margin: 0 auto;
      padding: clamp(52px, 7vw, 92px) var(--pad) 0;
    }
    .v2-hero-kicker {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 24px;
      color: var(--orange);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .18em;
    }
    .v2-hero-kicker::before { content: ''; width: 34px; height: 1px; background: currentColor; }
    .v2-hero-title {
      max-width: 820px;
      margin-bottom: 22px;
      font-size: clamp(42px, 5.8vw, 78px);
      font-weight: 900;
      line-height: 1.22;
      letter-spacing: -.035em;
    }
    .v2-hero-title > span { display: block; }
    .v2-hero-title em { color: var(--orange); font-style: normal; }
    .v2-hero-title.is-long { max-width: 790px; font-size: clamp(40px, 5vw, 68px); }
    .v2-hero-mobile-photo { display: none; }
    .v2-hero-lead {
      max-width: 620px;
      margin-bottom: 28px;
      color: #635950;
      font-size: clamp(14px, 1.5vw, 17px);
      font-weight: 500;
      line-height: 2;
      letter-spacing: .04em;
    }
    .v2-hero-actions { display: flex; align-items: center; flex-wrap: wrap; gap: 14px 20px; }
    .v2-primary-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 290px;
      padding: 18px 26px;
      background: var(--orange);
      color: #fff;
      font-size: 15px;
      font-weight: 800;
      letter-spacing: .07em;
      box-shadow: 0 12px 32px rgba(232,112,48,.3);
      transition: transform .2s, background .2s;
    }
    .v2-primary-btn:hover { transform: translateY(-2px); background: #d4612a; }
    .v2-hero-note { color: #83786f; font-size: 11.5px; line-height: 1.7; }
    .v2-proof-wrap { width: min(760px, 100%); margin-top: 46px; }
    .v2-proof-heading {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 14px;
      margin-bottom: 15px;
      color: #5e513f;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .16em;
      text-align: center;
    }
    .v2-proof-heading::before,
    .v2-proof-heading::after { content: ''; height: 1px; background: linear-gradient(90deg, transparent, rgba(178,135,55,.72)); }
    .v2-proof-heading::after { background: linear-gradient(90deg, rgba(178,135,55,.72), transparent); }
    .v2-proof-row {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }
    .v2-proof {
      position: relative;
      min-height: 174px;
      overflow: hidden;
      padding: 20px 20px 17px;
      border: 1px solid rgba(178,135,55,.72);
      border-radius: 3px;
      background: linear-gradient(145deg, #fff, #fffbf3);
      color: #241e1a;
      box-shadow: 0 14px 34px rgba(72,52,26,.13);
      isolation: isolate;
    }
    .v2-proof::before {
      content: '';
      position: absolute;
      z-index: 0;
      inset: 6px;
      border: 1px solid rgba(178,135,55,.25);
      pointer-events: none;
    }
    .v2-proof::after {
      content: '';
      position: absolute;
      left: 26px;
      right: 26px;
      bottom: 0;
      height: 3px;
      background: linear-gradient(90deg, transparent, #b28737, transparent);
    }
    .v2-proof > * { position: relative; z-index: 1; }
    .v2-proof-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 13px; }
    .v2-proof-seal {
      width: 42px;
      height: 42px;
      border: 1px solid #b28737;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: #fff;
      color: #9b7227;
      font-size: 11px;
      font-weight: 900;
      letter-spacing: .02em;
      box-shadow: 0 0 0 4px #fff, 0 0 0 5px rgba(178,135,55,.34);
    }
    .v2-proof-stars { color: #9b7227; font-size: 9px; font-weight: 800; letter-spacing: .14em; white-space: nowrap; }
    .v2-proof-label { color: #554c45; font-size: 11px; font-weight: 800; letter-spacing: .06em; }
    .v2-proof-value {
      display: flex;
      align-items: baseline;
      min-height: 49px;
      margin: 1px 0 3px;
      font-size: clamp(30px, 3.5vw, 44px);
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: -.035em;
      color: #211c18;
    }
    .v2-proof-value span { color: #a87927; font-size: .45em; margin-left: 4px; letter-spacing: .02em; }
    .v2-proof-value.is-text { font-size: clamp(27px, 3.1vw, 39px); letter-spacing: -.02em; }
    .v2-proof-value.is-review::before { content: '★'; margin-right: 5px; color: #a87927; font-size: .48em; }
    .v2-proof-desc { color: #776b62; font-size: 10px; font-weight: 700; line-height: 1.55; }
    .v2-slot {
      position: absolute;
      right: var(--pad);
      bottom: 34px;
      z-index: 3;
      width: 150px;
      height: 150px;
      border-radius: 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      background: var(--orange);
      color: #fff;
      box-shadow: 0 12px 36px rgba(180,82,31,.22);
      transform: rotate(5deg);
    }
    .v2-slot small { font-size: 10px; font-weight: 700; letter-spacing: .1em; }
    .v2-slot strong { font-size: 38px; font-weight: 900; line-height: 1.1; }
    .v2-slot span { font-size: 12px; font-weight: 700; }

    .v2-band { background: #f1e4d8; color: #3d3028; }
    .v2-band p { display: flex; justify-content: center; flex-wrap: wrap; gap: 10px 28px; }
    .v2-band p span { color: #3d3028; font-weight: 800; }
    .v2-band span::before { content: '✓'; margin-right: 8px; color: var(--orange); font-weight: 900; }

    .v2-section-head { max-width: 820px; margin-bottom: 42px; }
    .v2-eyebrow {
      margin-bottom: 12px;
      color: var(--orange);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .2em;
    }
    .v2-title {
      font-size: clamp(26px, 4.3vw, 50px);
      font-weight: 900;
      line-height: 1.45;
      letter-spacing: -.02em;
    }
    .v2-title em { color: var(--orange); font-style: normal; }
    .v2-lead { margin-top: 18px; color: var(--muted); font-size: 14px; line-height: 2.05; }

    .v2-pain-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .v2-pain-card {
      display: grid;
      grid-template-columns: 44px 1fr;
      gap: 14px;
      align-items: center;
      padding: 22px;
      border: 1px solid var(--border);
      background: #fff;
    }
    .v2-pain-no { color: #d5c6b9; font-size: 13px; font-weight: 800; letter-spacing: .08em; }
    .v2-pain-text { font-size: 14px; font-weight: 700; line-height: 1.7; }
    .v2-pain-answer {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 24px;
      align-items: center;
      margin-top: 28px;
      padding: 28px 32px;
      border: 1px solid #efd8c8;
      border-left: 5px solid var(--orange);
      background: #fff;
      color: var(--text);
      box-shadow: 0 12px 32px rgba(80,55,39,.07);
    }
    .v2-pain-answer b { color: var(--orange); font-size: 12px; letter-spacing: .16em; }
    .v2-pain-answer p { font-size: clamp(16px, 2.2vw, 22px); font-weight: 800; line-height: 1.6; }

    .v2-mini-cta {
      padding: 24px var(--pad);
      background: var(--orange-pale);
      border-top: 1px solid #f0d7c7;
      border-bottom: 1px solid #f0d7c7;
    }
    .v2-mini-cta-inner {
      width: min(920px, 100%);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 22px;
    }
    .v2-mini-cta-copy strong { display: block; font-size: 16px; line-height: 1.5; }
    .v2-mini-cta-copy span { color: var(--muted); font-size: 11.5px; }
    .v2-mini-cta-link {
      flex-shrink: 0;
      padding: 13px 22px;
      border: 1px solid var(--orange);
      background: #fff;
      color: var(--orange);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: .05em;
      transition: color .2s, background .2s;
    }
    .v2-mini-cta-link:hover { background: var(--orange); color: #fff; }

    .v2-method-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .v2-method-card {
      position: relative;
      overflow: hidden;
      min-height: 390px;
      display: flex;
      align-items: flex-end;
      background: #231e1a;
      color: #fff;
    }
    .v2-method-card img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: .58; }
    .v2-method-card::after { content: ''; position: absolute; inset: 34% 0 0; background: linear-gradient(transparent, rgba(20,17,15,.96)); }
    .v2-method-content { position: relative; z-index: 1; padding: 26px; }
    .v2-method-no { display: block; color: #f5a578; font-size: 11px; font-weight: 800; letter-spacing: .17em; }
    .v2-method-card h3 { margin: 8px 0 10px; font-size: 20px; line-height: 1.55; }
    .v2-method-card p { color: rgba(255,255,255,.7); font-size: 12.5px; line-height: 1.9; }
    .v2-method-effect {
      display: inline-flex;
      margin-top: 16px;
      padding: 6px 10px;
      border: 1px solid rgba(245,165,120,.5);
      color: #ffc19f;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: .08em;
    }
    .v2-method-option {
      display: grid;
      grid-template-columns: minmax(190px, .52fr) minmax(0, 1.48fr);
      gap: clamp(20px, 4vw, 44px);
      align-items: center;
      margin-top: 24px;
      padding: clamp(24px, 4vw, 36px);
      border: 1px solid #ead8ca;
      border-left: 5px solid var(--orange);
      background: #fff8f3;
    }
    .v2-method-option-label { color: var(--orange); font-size: 10px; font-weight: 800; line-height: 1.7; letter-spacing: .17em; }
    .v2-method-option strong { display: block; margin-bottom: 7px; font-size: clamp(17px, 2.2vw, 23px); line-height: 1.55; }
    .v2-method-option p { color: var(--muted); font-size: 12px; line-height: 1.85; }

    .v2-routine { background: linear-gradient(135deg, #f8f1eb, #f3e4d8); color: var(--text); }
    .v2-routine .v2-title { color: var(--text); }
    .v2-routine .v2-lead { color: var(--muted); }
    .v2-routine-grid { display: grid; grid-template-columns: 1fr 70px 1fr; align-items: stretch; }
    .v2-routine-card { padding: clamp(26px, 4vw, 42px); border: 1px solid #e4d7cc; background: rgba(255,255,255,.74); }
    .v2-routine-card.after { border-color: rgba(232,112,48,.7); background: #fff8f3; box-shadow: 0 16px 38px rgba(117,72,42,.08); }
    .v2-routine-label { margin-bottom: 24px; color: #8f837a; font-size: 11px; font-weight: 800; letter-spacing: .18em; }
    .v2-routine-card.after .v2-routine-label { color: var(--orange); }
    .v2-routine-list { display: flex; flex-direction: column; gap: 16px; }
    .v2-routine-list li { display: flex; gap: 12px; color: #62584f; font-size: 13px; line-height: 1.75; }
    .v2-routine-list li span {
      flex: 0 0 25px;
      height: 25px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid #cfc0b5;
      color: #8f837a;
      font-size: 10px;
      font-weight: 800;
    }
    .v2-routine-card.after li span { border-color: var(--orange); background: var(--orange); color: #fff; }
    .v2-routine-arrow { display: flex; align-items: center; justify-content: center; color: var(--orange); font-size: 28px; }

    .v2-proof-intro {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 36px;
    }
    .v2-proof-note { max-width: 360px; color: var(--light); font-size: 10.5px; line-height: 1.7; text-align: right; }
    .v2-section-footnote { margin-top: 18px; color: var(--light); font-size: 10.5px; line-height: 1.7; }

    .v2-value {
      display: grid;
      grid-template-columns: minmax(0, .92fr) minmax(0, 1.08fr);
      align-items: stretch;
    }
    .v2-value-copy {
      position: relative;
      overflow: hidden;
      padding: clamp(34px, 5vw, 58px);
      border: 1px solid #2d2621;
      background: linear-gradient(145deg, #302822, #211c18);
      color: #fff;
    }
    .v2-value-copy::after {
      content: '';
      position: absolute;
      right: -90px;
      bottom: -130px;
      width: 280px;
      height: 280px;
      border: 1px solid rgba(232,112,48,.32);
      border-radius: 50%;
      box-shadow: 0 0 0 42px rgba(232,112,48,.05);
    }
    .v2-value-copy > * { position: relative; z-index: 1; }
    .v2-value-copy .v2-title { color: #fff; }
    .v2-value-copy .v2-lead { color: rgba(255,255,255,.68); }
    .v2-value-price {
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: end;
      gap: 4px 12px;
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px solid rgba(255,255,255,.18);
    }
    .v2-value-price small { color: #f5a578; font-size: 11px; font-weight: 800; letter-spacing: .14em; }
    .v2-value-price strong { grid-column: 1 / -1; color: #fff; font-size: clamp(42px, 5vw, 64px); line-height: 1; letter-spacing: -.045em; }
    .v2-value-price strong sup { color: var(--orange); font-size: .48em; vertical-align: .7em; }
    .v2-value-price span { grid-column: 1 / -1; color: rgba(255,255,255,.58); font-size: 11px; font-weight: 700; letter-spacing: .05em; }
    .v2-value-visual {
      position: relative;
      min-height: 520px;
      overflow: hidden;
      background: #171412;
    }
    .v2-value-visual::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(0deg, rgba(255,250,246,.9) 0%, rgba(255,250,246,0) 54%);
    }
    .v2-value-visual img { width: 100%; height: 100%; object-fit: cover; object-position: center; filter: saturate(.82) contrast(1.05); }
    .v2-value-facts {
      position: absolute;
      z-index: 1;
      right: clamp(20px, 3vw, 34px);
      bottom: clamp(20px, 3vw, 34px);
      left: clamp(20px, 3vw, 34px);
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: 1px solid rgba(218,194,177,.86);
      background: rgba(255,252,249,.9);
      backdrop-filter: blur(10px);
    }
    .v2-value-fact { padding: 18px 14px; color: #756960; font-size: 10px; font-weight: 700; line-height: 1.6; text-align: center; }
    .v2-value-fact + .v2-value-fact { border-left: 1px solid #e4d6cc; }
    .v2-value-fact strong { display: block; margin-bottom: 4px; color: var(--text); font-size: 15px; }

    .v2-nutrition-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(400px, .92fr);
      align-items: stretch;
      background: #f7f3ee;
    }
    .v2-nutrition-copy { padding: clamp(38px, 6vw, 72px); }
    .v2-nutrition-points { display: grid; gap: 18px; margin-top: 30px; }
    .v2-nutrition-point { display: grid; grid-template-columns: 30px 1fr; gap: 12px; align-items: start; }
    .v2-nutrition-check {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: var(--orange);
      color: #fff;
      font-size: 14px;
      font-weight: 900;
    }
    .v2-nutrition-point strong { display: block; margin-bottom: 5px; font-size: 14px; line-height: 1.6; }
    .v2-nutrition-point p { color: var(--muted); font-size: 11.5px; line-height: 1.75; }
    .v2-nutrition-visual { position: relative; min-height: 590px; overflow: hidden; background: #f5f0e9; }
    .v2-nutrition-visual img { width: 100%; height: 100%; object-fit: cover; object-position: 66% center; }
    .v2-credential-card {
      position: absolute;
      bottom: clamp(18px, 3vw, 34px);
      left: clamp(18px, 3vw, 34px);
      display: block;
      width: min(58%, 370px);
      padding: 8px;
      border: 1px solid rgba(190,140,66,.5);
      background: #fff;
      box-shadow: 0 18px 45px rgba(52,39,27,.18);
      color: var(--text);
      text-decoration: none;
    }
    .v2-credential-card img { display: block; width: 100%; height: auto; object-fit: contain; }
    .v2-credential-caption { display: flex; justify-content: space-between; gap: 10px; padding: 8px 4px 2px; color: #8b6a36; font-size: 9px; font-weight: 800; letter-spacing: .08em; }
    .v2-hero + .v2-band { box-shadow: 0 8px 24px rgba(86,57,39,.05); }
    .v2-routine + .sec-white { border-top: 1px solid #eadfd6; }
    #trainers .trainer-panel { background: #2b241f; color: #fff; }
    #trainers .trainer-jp { color: rgba(255,255,255,.5); }
