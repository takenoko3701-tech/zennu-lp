<style>
  /* /1/ only: appearance-first appeal variant */
  :root {
    --v1-ink: #211d1a;
    --v1-brown: #4a382c;
    --v1-gold: #b68737;
    --v1-gold-deep: #8a6426;
    --v1-ivory: #fbf7f0;
    --v1-line: rgba(74, 56, 44, .16);
  }

  .site-header:not(.scrolled) .logo-img { filter: brightness(0); }
  .site-header:not(.scrolled) .site-nav a { color: rgba(33, 29, 26, .76); }
  .site-header:not(.scrolled) .site-nav a:hover { color: var(--orange); background: rgba(232, 112, 48, .08); }
  .site-header:not(.scrolled) .ham-btn span { background: var(--v1-ink); }

  .v1-hero {
    position: relative;
    min-height: 780px;
    overflow: hidden;
    background: var(--v1-ivory);
    color: var(--v1-ink);
  }
  .v1-hero::before {
    content: '';
    position: absolute;
    z-index: 1;
    inset: 0;
    background: linear-gradient(90deg, #fbf7f0 0%, #fbf7f0 42%, rgba(251, 247, 240, .92) 51%, rgba(251, 247, 240, .08) 72%);
    pointer-events: none;
  }
  .v1-hero::after {
    content: '';
    position: absolute;
    z-index: 1;
    left: -160px;
    bottom: -330px;
    width: 680px;
    height: 680px;
    border: 1px solid rgba(182, 135, 55, .24);
    border-radius: 50%;
    box-shadow: 0 0 0 72px rgba(182, 135, 55, .035), 0 0 0 144px rgba(182, 135, 55, .018);
    pointer-events: none;
  }
  .v1-hero-photo { position: absolute; inset: 0 0 0 43%; }
  .v1-hero-photo img { width: 100%; height: 100%; object-fit: cover; object-position: 58% center; filter: saturate(.86) contrast(1.02); }
  .v1-hero-inner {
    position: relative;
    z-index: 2;
    width: min(1200px, 100%);
    min-height: 780px;
    margin: 0 auto;
    padding: 148px var(--pad) 56px;
  }
  .v1-hero-copy { max-width: 650px; }
  .v1-kicker,
  .v1-eyebrow {
    color: var(--v1-gold-deep);
    font-family: var(--display);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .2em;
  }
  .v1-kicker { display: flex; align-items: center; gap: 12px; margin-bottom: 25px; }
  .v1-kicker::before { content: ''; width: 38px; height: 1px; background: currentColor; }
  .v1-hero-title {
    margin-bottom: 25px;
    font-size: clamp(48px, 6vw, 82px);
    font-weight: 900;
    line-height: 1.18;
    letter-spacing: -.055em;
  }
  .v1-hero-title em,
  .v1-section-title em { color: var(--orange); font-style: normal; }
  .v1-hero-lead {
    max-width: 580px;
    margin-bottom: 30px;
    color: #625950;
    font-size: clamp(14px, 1.55vw, 17px);
    font-weight: 500;
    line-height: 2;
    letter-spacing: .035em;
  }
  .v1-hero-actions { display: flex; align-items: center; flex-wrap: wrap; gap: 14px 20px; }
  .v1-primary-btn {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
    min-width: 300px;
    padding: 18px 22px 18px 26px;
    border: 1px solid var(--orange);
    background: var(--orange);
    color: #fff;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: .07em;
    box-shadow: 0 14px 36px rgba(198, 86, 30, .25);
    transition: transform .2s, background .2s;
  }
  .v1-primary-btn:hover { transform: translateY(-2px); background: #d4612a; }
  .v1-primary-btn span { font-size: 18px; }
  .v1-hero-note { color: #83796f; font-size: 11px; line-height: 1.7; }
  .v1-case-card {
    position: absolute;
    left: var(--pad);
    bottom: 54px;
    width: min(590px, calc(100% - var(--pad) * 2));
    padding: 17px 22px 15px;
    border: 1px solid rgba(182, 135, 55, .58);
    background: rgba(255, 253, 249, .94);
    color: var(--v1-ink);
    box-shadow: 0 18px 48px rgba(53, 39, 28, .14);
    backdrop-filter: blur(9px);
  }
  .v1-case-card::before { content: ''; position: absolute; inset: 6px; border: 1px solid rgba(182, 135, 55, .18); pointer-events: none; }
  .v1-case-card > * { position: relative; z-index: 1; }
  .v1-case-head { display: flex; justify-content: space-between; gap: 12px; margin-bottom: 8px; color: #867866; font-size: 9px; font-weight: 800; letter-spacing: .12em; }
  .v1-case-values { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 18px; }
  .v1-case-values > div { display: flex; align-items: baseline; justify-content: center; gap: 9px; }
  .v1-case-values small { color: #625950; font-size: 11px; font-weight: 800; }
  .v1-case-values strong { font-size: clamp(32px, 4vw, 47px); line-height: 1; letter-spacing: -.045em; }
  .v1-case-values sup { margin-left: 3px; color: var(--v1-gold-deep); font-size: .42em; vertical-align: .65em; }
  .v1-case-values .is-accent strong { color: var(--orange); }
  .v1-case-divider { color: #9a9087; font-family: var(--serif); font-size: 11px; }
  .v1-case-card > p { margin-top: 6px; color: #877c73; font-size: 9.5px; text-align: center; }
  .v1-case-link { position: absolute; right: 12px; bottom: 6px; color: var(--v1-gold-deep); font-size: 8.5px; font-weight: 800; letter-spacing: .04em; }

  .v1-awards { position: relative; z-index: 3; background: #28231f; color: #fff; }
  .v1-awards-inner {
    display: grid;
    grid-template-columns: .92fr repeat(3, 1fr);
    width: min(1200px, 100%);
    margin: 0 auto;
    padding: 28px var(--pad);
  }
  .v1-awards-intro { display: flex; flex-direction: column; justify-content: center; padding-right: 28px; border-right: 1px solid rgba(255, 255, 255, .12); }
  .v1-awards-intro span { margin-bottom: 8px; color: #d8b571; font-size: 9px; font-weight: 800; letter-spacing: .17em; }
  .v1-awards-intro strong { font-family: var(--serif); font-size: 18px; line-height: 1.55; }
  .v1-award { display: grid; grid-template-columns: 88px 1fr; align-items: center; gap: 4px; min-width: 0; padding-left: 18px; }
  .v1-award + .v1-award { border-left: 1px solid rgba(255, 255, 255, .1); }
  .v1-award-seal { position: relative; width: 82px; height: 82px; }
  .v1-award-seal .laurel-svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .v1-award-copy > span { display: block; color: #d8c9b1; font-size: 9px; font-weight: 800; letter-spacing: .08em; }
  .v1-award-copy strong { display: block; margin: 2px 0 4px; color: #fff; font-size: 34px; line-height: 1; letter-spacing: -.045em; }
  .v1-award-copy strong small { margin-left: 2px; color: #d8b571; font-size: .5em; }
  .v1-award-copy p { color: rgba(255, 255, 255, .5); font-size: 8.5px; line-height: 1.4; }

  .v1-section-shell { width: min(1200px, 100%); margin: 0 auto; padding: clamp(78px, 10vw, 126px) var(--pad); }
  .v1-section-head { max-width: 840px; margin-bottom: 46px; }
  .v1-eyebrow { margin-bottom: 13px; }
  .v1-section-title {
    color: var(--v1-ink);
    font-size: clamp(30px, 4.2vw, 52px);
    font-weight: 900;
    line-height: 1.38;
    letter-spacing: -.035em;
  }
  .v1-section-lead { max-width: 690px; margin-top: 20px; color: #71675e; font-size: 14px; line-height: 2; letter-spacing: .035em; }

  .v1-insight { position: relative; overflow: hidden; background: #fff; }
  .v1-insight::before { content: 'MIRROR'; position: absolute; right: -18px; top: 65px; color: rgba(36, 29, 24, .026); font-family: var(--display); font-size: clamp(90px, 18vw, 260px); font-weight: 900; letter-spacing: -.08em; }
  .v1-insight-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .v1-insight-card { min-height: 330px; padding: 34px; border: 1px solid var(--v1-line); background: var(--v1-ivory); }
  .v1-insight-card > span,
  .v1-insight-card > div > span { color: var(--v1-gold-deep); font-size: 9px; font-weight: 800; letter-spacing: .16em; }
  .v1-insight-card h3 { margin: 68px 0 18px; font-family: var(--serif); font-size: clamp(20px, 2.3vw, 27px); line-height: 1.62; }
  .v1-insight-card p { color: #756c64; font-size: 12.5px; line-height: 1.9; }
  .v1-insight-card.is-dark { border-color: #2a2521; background: #2a2521; color: #fff; }
  .v1-insight-card.is-dark h3 { color: #fff; }
  .v1-insight-card.is-dark p { color: rgba(255, 255, 255, .59); }
  .v1-insight-card.is-photo { position: relative; overflow: hidden; padding: 0; color: #fff; }
  .v1-insight-card.is-photo::after { content: ''; position: absolute; inset: 25% 0 0; background: linear-gradient(transparent, rgba(20, 17, 15, .94)); }
  .v1-insight-card.is-photo img { width: 100%; height: 100%; object-fit: cover; }
  .v1-insight-card.is-photo > div { position: absolute; z-index: 1; left: 32px; right: 32px; bottom: 30px; }
  .v1-insight-card.is-photo h3 { margin: 10px 0 0; color: #fff; }

  .v1-results { background: #f1e9df; }
  .v1-result-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .v1-result-card { overflow: hidden; background: #fff; box-shadow: 0 14px 36px rgba(69, 49, 35, .08); }
  .v1-result-image { position: relative; aspect-ratio: 4 / 3; overflow: hidden; background: #e7e3df; }
  .v1-result-image img { width: 100%; height: 100%; object-fit: cover; }
  .v1-result-image > span { position: absolute; left: 14px; bottom: 14px; padding: 7px 10px; background: #2a2521; color: #fff; font-size: 10px; font-weight: 800; }
  .v1-result-body { padding: 22px 22px 25px; }
  .v1-result-body > p { color: #968a81; font-size: 9px; font-weight: 700; letter-spacing: .05em; }
  .v1-result-body h3 { margin: 6px 0 18px; font-size: 15px; }
  .v1-result-numbers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .v1-result-numbers > div { padding: 10px 5px; border-top: 1px solid var(--v1-line); text-align: center; }
  .v1-result-numbers small { display: block; margin-bottom: 5px; color: #857a72; font-size: 8px; }
  .v1-result-numbers strong { color: var(--v1-ink); font-size: clamp(20px, 2.4vw, 27px); letter-spacing: -.04em; }
  .v1-result-numbers strong span { margin-left: 1px; color: var(--v1-gold-deep); font-size: .48em; }
  .v1-result-numbers .is-accent { border-color: var(--orange); }
  .v1-result-numbers .is-accent strong { color: var(--orange); }
  .v1-result-note { margin-top: 20px; color: #8f837a; font-size: 10px; }

  .v1-method { background: #fff; }
  .v1-method-layout { display: grid; grid-template-columns: .86fr 1.14fr; gap: clamp(48px, 7vw, 90px); }
  .v1-method-copy { position: sticky; top: 110px; align-self: start; }
  .v1-text-link { display: inline-flex; gap: 30px; margin-top: 28px; padding-bottom: 6px; border-bottom: 1px solid var(--v1-gold); color: var(--v1-gold-deep); font-size: 12px; font-weight: 800; letter-spacing: .05em; }
  .v1-method-steps { display: grid; gap: 0; }
  .v1-method-steps article { position: relative; padding: 8px 0 38px 78px; border-left: 1px solid rgba(182, 135, 55, .36); }
  .v1-method-steps article::before { content: ''; position: absolute; left: -6px; top: 8px; width: 11px; height: 11px; border: 3px solid #fff; border-radius: 50%; background: var(--v1-gold); box-shadow: 0 0 0 1px var(--v1-gold); }
  .v1-method-steps article:last-child { padding-bottom: 8px; }
  .v1-method-steps span { color: var(--v1-gold-deep); font-size: 9px; font-weight: 800; letter-spacing: .16em; }
  .v1-method-steps h3 { margin: 9px 0 10px; font-size: clamp(20px, 2.3vw, 27px); }
  .v1-method-steps p { color: #776d65; font-size: 12.5px; line-height: 1.9; }
  .v1-capacity { display: grid; grid-template-columns: 1fr 1fr auto; align-items: center; gap: 0; margin-top: 76px; border: 1px solid var(--v1-line); background: var(--v1-ivory); }
  .v1-capacity > div { padding: 24px 28px; }
  .v1-capacity > div + div { border-left: 1px solid var(--v1-line); }
  .v1-capacity span { display: block; margin-bottom: 7px; color: var(--v1-gold-deep); font-size: 9px; font-weight: 800; letter-spacing: .14em; }
  .v1-capacity strong { display: block; color: var(--v1-ink); font-size: 23px; letter-spacing: -.02em; }
  .v1-capacity p { margin-top: 5px; color: #82776e; font-size: 10px; }
  .v1-capacity > a { align-self: stretch; display: flex; align-items: center; padding: 0 28px; background: var(--v1-ink); color: #fff; font-size: 11px; font-weight: 800; }

  .v1-credential { overflow: hidden; background: #2a2521; color: #fff; }
  .v1-credential-grid { display: grid; grid-template-columns: 1fr 1fr; min-height: 700px; }
  .v1-credential-copy { align-self: center; padding: clamp(68px, 8vw, 112px) max(var(--pad), calc((100vw - 1200px) / 2 + var(--pad))) clamp(68px, 8vw, 112px) var(--pad); }
  .v1-credential-copy .v1-section-title { color: #fff; }
  .v1-credential-copy .v1-section-lead { color: rgba(255, 255, 255, .6); }
  .v1-credential-list { display: grid; gap: 20px; margin-top: 34px; }
  .v1-credential-list li { display: grid; grid-template-columns: 30px 1fr; gap: 14px; }
  .v1-credential-list li > span { display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; border: 1px solid rgba(216, 181, 113, .52); border-radius: 50%; color: #d8b571; font-size: 8px; font-weight: 800; }
  .v1-credential-list strong { display: block; margin-bottom: 5px; font-size: 14px; }
  .v1-credential-list p { color: rgba(255, 255, 255, .52); font-size: 11.5px; line-height: 1.7; }
  .v1-credential-visual { position: relative; min-height: 700px; overflow: hidden; background: #f7f2eb; }
  .v1-credential-person { width: 100%; height: 100%; object-fit: cover; object-position: 67% center; }
  .v1-certificate { position: absolute; right: 6%; bottom: 7%; width: min(47%, 310px); padding: 9px; border: 1px solid rgba(182, 135, 55, .62); background: rgba(255, 253, 248, .96); color: var(--v1-ink); box-shadow: 0 18px 54px rgba(46, 31, 20, .28); transform: rotate(1.5deg); }
  .v1-certificate > img { width: 100%; aspect-ratio: 1.3 / 1; object-fit: cover; object-position: top center; }
  .v1-certificate > span { display: flex; align-items: center; justify-content: space-between; gap: 8px; padding: 9px 4px 2px; }
  .v1-certificate strong { font-size: 9px; }
  .v1-certificate small { color: var(--v1-gold-deep); font-size: 8px; font-weight: 800; }

  .v1-mid-cta { padding: 0 var(--pad); background: #fff; }
  .v1-mid-cta-inner { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 32px; width: min(1200px, 100%); margin: 0 auto; padding: 46px 0; }
  .v1-mid-cta-inner > div > span { color: var(--v1-gold-deep); font-size: 9px; font-weight: 800; letter-spacing: .16em; }
  .v1-mid-cta-inner strong { display: block; margin: 8px 0; color: var(--v1-ink); font-family: var(--serif); font-size: clamp(20px, 2.8vw, 31px); line-height: 1.55; }
  .v1-mid-cta-inner p { color: #80756d; font-size: 11px; }
  .v1-mid-cta-inner > a { display: flex; align-items: center; justify-content: space-between; gap: 38px; min-width: 290px; padding: 18px 22px; background: var(--orange); color: #fff; font-size: 13px; font-weight: 800; box-shadow: 0 12px 32px rgba(198, 86, 30, .22); }

  @media (max-width: 1040px) {
    .v1-awards-inner { grid-template-columns: repeat(3, 1fr); }
    .v1-awards-intro { grid-column: 1 / -1; flex-direction: row; align-items: center; gap: 24px; padding: 0 0 20px; border-right: 0; border-bottom: 1px solid rgba(255, 255, 255, .12); }
    .v1-awards-intro span { margin: 0; }
    .v1-awards-intro strong br { display: none; }
    .v1-award { padding-top: 18px; }
    .v1-award:first-of-type { padding-left: 0; }
    .v1-method-layout { grid-template-columns: 1fr; }
    .v1-method-copy { position: static; }
    .v1-method-steps { max-width: 760px; }
    .v1-capacity { grid-template-columns: 1fr 1fr; }
    .v1-capacity > a { grid-column: 1 / -1; justify-content: center; padding: 18px 28px; }
    .v1-credential-grid { grid-template-columns: 1fr; }
    .v1-credential-copy { padding-left: var(--pad); padding-right: var(--pad); }
    .v1-credential-visual { min-height: 640px; }
  }

  @media (max-width: 760px) {
    .v1-hero { min-height: auto; padding-bottom: 0; }
    .v1-hero::before { background: linear-gradient(180deg, rgba(251, 247, 240, .98) 0%, rgba(251, 247, 240, .92) 45%, rgba(251, 247, 240, .15) 72%, rgba(33, 29, 26, .62) 100%); }
    .v1-hero-photo { inset: 0; }
    .v1-hero-photo img { object-position: 58% center; }
    .v1-hero-inner { min-height: 730px; padding-top: 108px; padding-bottom: 24px; display: flex; flex-direction: column; }
    .v1-hero-copy { max-width: none; }
    .v1-hero-title { font-size: clamp(40px, 12vw, 58px); }
    .v1-hero-lead { max-width: 470px; font-size: 13px; }
    .v1-case-card { position: relative; left: auto; bottom: auto; width: 100%; margin-top: auto; }
    .v1-awards-inner { grid-template-columns: 1fr; padding-top: 22px; padding-bottom: 22px; }
    .v1-awards-intro { display: none; }
    .v1-award { grid-template-columns: 74px 1fr; padding: 9px 0; }
    .v1-award + .v1-award { border-left: 0; border-top: 1px solid rgba(255, 255, 255, .1); }
    .v1-award-seal { width: 68px; height: 68px; }
    .v1-award-copy strong { font-size: 30px; }
    .v1-insight-grid,
    .v1-result-grid { grid-template-columns: 1fr; }
    .v1-insight-card { min-height: 290px; }
    .v1-result-card { display: grid; grid-template-columns: minmax(140px, .85fr) 1.15fr; }
    .v1-result-image { aspect-ratio: auto; min-height: 230px; }
    .v1-result-body { align-self: center; padding: 20px 16px; }
    .v1-result-numbers { grid-template-columns: 1fr; }
    .v1-result-numbers > div { display: flex; align-items: baseline; justify-content: space-between; padding: 7px 0; text-align: left; }
    .v1-result-numbers small { margin: 0; }
    .v1-result-numbers strong { font-size: 22px; }
    .v1-method-steps article { padding-left: 45px; }
    .v1-capacity { grid-template-columns: 1fr; }
    .v1-capacity > div + div { border-left: 0; border-top: 1px solid var(--v1-line); }
    .v1-capacity > a { grid-column: auto; }
    .v1-credential-visual { min-height: 560px; }
    .v1-mid-cta-inner { grid-template-columns: 1fr; }
    .v1-mid-cta-inner > a { min-width: 0; }
  }

  @media (max-width: 480px) {
    .v1-hero-inner { min-height: 700px; padding-top: 98px; }
    .v1-kicker { font-size: 9px; letter-spacing: .13em; }
    .v1-hero-title { font-size: 40px; }
    .v1-hero-lead br { display: none; }
    .v1-primary-btn { width: 100%; min-width: 0; }
    .v1-hero-note { display: none; }
    .v1-case-card { padding: 15px 15px 14px; }
    .v1-case-head { font-size: 8px; }
    .v1-case-values { gap: 8px; }
    .v1-case-values > div { display: block; text-align: center; }
    .v1-case-values small { display: block; margin-bottom: 3px; }
    .v1-case-values strong { font-size: 32px; }
    .v1-section-shell { padding-top: 68px; padding-bottom: 68px; }
    .v1-section-title { font-size: 29px; }
    .v1-result-card { grid-template-columns: 1fr; }
    .v1-result-image { min-height: 0; aspect-ratio: 4 / 3; }
    .v1-result-numbers { grid-template-columns: repeat(3, 1fr); }
    .v1-result-numbers > div { display: block; padding: 9px 3px; text-align: center; }
    .v1-result-numbers small { margin-bottom: 5px; }
    .v1-credential-visual { min-height: 500px; }
    .v1-certificate { width: 54%; }
  }
</style>
