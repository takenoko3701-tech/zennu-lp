  <style>
    :root {
      --v3-navy: #132846;
      --v3-navy-deep: #0b192d;
      --v3-blue: #35a3e7;
      --v3-green: #54d47e;
      --v3-aqua: #eaf3f5;
      --v3-aqua-2: #dcecef;
      --v3-orange: #ee772e;
      --v3-orange-dark: #db5b1e;
      --v3-gold: #e6b95d;
      --v3-gold-light: #fff0b4;
      --v3-ink: #17243a;
      --v3-muted: #657082;
      --v3-line: #d5e1e5;
      --v3-white: #fff;
      --v3-max: 1160px;
      --v3-pad: clamp(20px, 4.8vw, 64px);
      --v3-grad: linear-gradient(110deg, var(--v3-blue), var(--v3-green));
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { overflow-x: hidden; background: #fff; color: var(--v3-ink); font-family: "Noto Sans JP", sans-serif; }
    img { display: block; width: 100%; }
    a { color: inherit; text-decoration: none; }
    button { border: 0; background: none; color: inherit; font: inherit; }
    .v3-en { font-family: "Montserrat", sans-serif; }

    .v3-header { position: fixed; z-index: 100; top: 0; left: 0; right: 0; height: 72px; background: rgba(255,255,255,.97); border-bottom: 1px solid rgba(19,40,70,.12); }
    .v3-header-inner { display: flex; align-items: center; justify-content: space-between; gap: 24px; width: min(var(--v3-max), 100%); height: 100%; margin: auto; padding: 0 var(--v3-pad); }
    .v3-logo img { width: clamp(190px, 18vw, 235px); filter: brightness(0); }
    .v3-header-copy { margin-right: auto; color: var(--v3-navy); font-size: 10px; font-weight: 700; letter-spacing: .12em; }
    .v3-header-cta { display: inline-flex; align-items: center; gap: 12px; padding: 13px 20px; background: var(--v3-orange); color: #fff; font-size: 12px; font-weight: 900; box-shadow: 0 5px 0 var(--v3-orange-dark); }
    .v3-header-cta i { font-style: normal; }

    .v3-hero { position: relative; min-height: 700px; padding-top: 72px; overflow: hidden; background: var(--v3-navy-deep); color: #fff; }
    .v3-hero-media { position: absolute; inset: 72px 0 0 37%; display: grid; grid-template-columns: 1.15fr .72fr; gap: 5px; }
    .v3-hero-main, .v3-hero-side > div { overflow: hidden; background: #20344e; }
    .v3-hero-main { clip-path: polygon(12% 0,100% 0,89% 100%,0 100%); margin-left: -11%; }
    .v3-hero-side { display: grid; grid-template-rows: 1fr 1fr; gap: 5px; margin-left: -10%; }
    .v3-hero-media img { height: 100%; object-fit: cover; }
    .v3-hero-main img { object-position: 52% center; }
    .v3-hero-side > div:first-child img { object-position: 75% center; }
    .v3-hero-side > div:last-child img { object-position: 68% center; }
    .v3-hero::before { content: ""; position: absolute; z-index: 1; inset: 72px 0 0; background: linear-gradient(90deg,#10253f 0%,#10253f 34%,rgba(16,37,63,.92) 43%,rgba(16,37,63,.28) 67%,rgba(16,37,63,.12) 100%); }
    .v3-hero-inner { position: relative; z-index: 2; width: min(var(--v3-max), 100%); min-height: 628px; margin: auto; padding: 58px var(--v3-pad) 34px; }
    .v3-hero-copy { width: min(620px, 58%); }
    .v3-hero-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 22px; }
    .v3-hero-tags span { min-width: 110px; padding: 9px 15px; transform: skew(-12deg); background: var(--v3-grad); font-size: 11px; font-weight: 800; text-align: center; letter-spacing: .1em; }
    .v3-hero-tags i { display: block; transform: skew(12deg); font-style: normal; }
    .v3-hero-kicker { margin-bottom: 7px; font-size: clamp(17px,2vw,25px); font-weight: 500; letter-spacing: .16em; }
    .v3-hero-title { white-space: nowrap; font-size: clamp(46px,4.8vw,64px); font-weight: 800; line-height: 1.25; letter-spacing: -.03em; }
    .v3-hero-title em { background: var(--v3-grad); -webkit-background-clip: text; background-clip: text; color: transparent; font-style: normal; }
    .v3-hero-sub { margin-top: 10px; font-size: clamp(22px,2.6vw,34px); font-weight: 500; line-height: 1.5; letter-spacing: .08em; }
    .v3-hero-lead { margin-top: 14px; font-size: 12px; font-weight: 600; line-height: 1.85; }
    .v3-hero-price { display: flex; align-items: flex-end; gap: 14px; margin-top: 15px; }
    .v3-price-label { display: grid; place-items: center; width: 50px; height: 86px; border: 1px solid rgba(255,255,255,.75); font-size: 11px; font-weight: 800; line-height: 1.6; }
    .v3-hero-price p { line-height: 1; }
    .v3-hero-price small { display: block; margin-bottom: 8px; font-size: 14px; font-weight: 700; }
    .v3-hero-price strong { display: inline-block; padding-right: .1em; background: var(--v3-grad); -webkit-background-clip: text; background-clip: text; color: transparent; font-family: "Montserrat",sans-serif; font-size: clamp(60px,7vw,92px); font-weight: 800; letter-spacing: -.035em; }
    .v3-hero-price b { padding-bottom: 7px; font-size: 26px; font-weight: 500; }
    .v3-hero-note { margin-top: 10px; color: rgba(255,255,255,.62); font-size: 9px; }
    .v3-hero-proof { display: grid; grid-template-columns: repeat(3,136px); gap: 13px; margin-top: 18px; }
    .v3-proof-medal { position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; aspect-ratio: 1/1; padding: 25px 10px 14px; border: 2px solid var(--v3-gold); border-radius: 50%; background: radial-gradient(circle at 50% 42%,rgba(255,239,181,.15),rgba(9,25,45,.86) 68%); color: #fff; text-align: center; box-shadow: inset 0 0 0 4px rgba(230,185,93,.16),0 8px 24px rgba(0,0,0,.22); }
    .v3-proof-medal::before,.v3-proof-medal::after { content: ""; position: absolute; top: 24%; width: 18px; height: 58%; border-top: 2px solid var(--v3-gold); border-bottom: 2px solid var(--v3-gold); opacity: .8; }
    .v3-proof-medal::before { left: -9px; border-left: 3px solid var(--v3-gold); border-radius: 70% 0 0 70%; transform: rotate(-13deg); }
    .v3-proof-medal::after { right: -9px; border-right: 3px solid var(--v3-gold); border-radius: 0 70% 70% 0; transform: rotate(13deg); }
    .v3-proof-crown { position: absolute; top: 8px; color: var(--v3-gold-light); font-size: 18px; line-height: 1; text-shadow: 0 2px 7px rgba(230,185,93,.5); }
    .v3-hero-proof small { display: block; font-size: 8px; font-weight: 700; letter-spacing: .08em; }
    .v3-hero-proof strong { display: block; margin-top: 1px; color: var(--v3-gold-light); font-family: "Montserrat",sans-serif; font-size: 27px; line-height: 1.2; }
    .v3-hero-proof strong span { font-family: "Noto Sans JP",sans-serif; font-size: 11px; }
    .v3-proof-medal.is-credential strong { font-size: 21px; letter-spacing: -.04em; }
    .v3-proof-medal.is-credential strong span { display: block; margin-top: 3px; font-size: 9px; }
    .v3-proof-medal.is-review strong { font-size: 34px; }
    .v3-proof-stars { margin-top: 1px; color: var(--v3-gold); font-size: 7px; letter-spacing: .12em; }
    .v3-hero-proof-note { max-width: 460px; margin-top: 10px; color: rgba(255,255,255,.56); font-size: 8px; line-height: 1.65; }

    .v3-offer { position: relative; z-index: 4; background: var(--v3-aqua); border-top: 1px solid #d4e4e7; border-bottom: 1px solid #d4e4e7; }
    .v3-offer-inner { display: grid; grid-template-columns: .9fr 1.1fr; align-items: center; width: min(var(--v3-max),100%); min-height: 156px; margin: auto; padding: 22px var(--v3-pad); }
    .v3-offer-message { display: flex; align-items: center; gap: 22px; }
    .v3-offer-icon { display: grid; place-items: center; flex: 0 0 92px; height: 92px; clip-path: polygon(0 0,78% 0,100% 50%,78% 100%,0 100%); background: var(--v3-grad); color: #fff; font-size: 14px; font-weight: 900; text-align: center; line-height: 1.4; }
    .v3-offer-message p { font-size: 17px; font-weight: 700; line-height: 1.75; letter-spacing: .08em; }
    .v3-offer-message strong { text-decoration: underline; text-decoration-color: #ffd04c; text-decoration-thickness: 5px; text-underline-offset: 3px; }
    .v3-offer-action { position: relative; padding-top: 26px; }
    .v3-offer-limit { position: absolute; z-index: 2; top: 0; left: 7%; right: 7%; padding: 8px; border-radius: 30px; background: #fff28d; color: #8c4b19; font-size: 11px; font-weight: 900; text-align: center; }
    .v3-offer-btn { display: flex; align-items: center; justify-content: center; gap: 18px; min-height: 74px; padding: 16px 24px; border: 3px solid #fff; background: linear-gradient(#fa983e,#ee6f25); color: #fff; font-size: 20px; font-weight: 900; box-shadow: 0 6px 0 #c95319,0 8px 20px rgba(110,64,35,.18); }
    .v3-offer-btn span { display: grid; place-items: center; width: 48px; height: 48px; border: 1px solid rgba(255,255,255,.78); border-radius: 50%; font-size: 10px; line-height: 1.2; }
    .v3-offer-btn b { font-size: 24px; }

    .v3-section { padding: 92px var(--v3-pad); }
    .v3-inner { width: min(var(--v3-max),100%); margin: auto; }
    .v3-heading { margin-bottom: 46px; text-align: center; }
    .v3-heading h2 { color: var(--v3-navy); font-size: clamp(31px,4vw,47px); font-weight: 500; line-height: 1.55; letter-spacing: .08em; }
    .v3-heading h2 strong { font-weight: 800; }
    .v3-heading h2 em { color: #37b6a6; font-style: normal; }
    .v3-heading p { margin-top: 8px; color: #55b7ac; font-family: "Montserrat",sans-serif; font-size: 12px; letter-spacing: .25em; }
    .v3-lead { max-width: 760px; margin: 22px auto 0; color: var(--v3-muted); font-size: 13px; line-height: 2; text-align: center; }

    .v3-intro { background: #fff; }
    .v3-intro-grid { display: grid; grid-template-columns: 1fr 1fr; align-items: center; gap: 54px; }
    .v3-intro-photo { position: relative; }
    .v3-intro-photo::before { content: ""; position: absolute; z-index: 0; top: -18px; left: -18px; width: 58%; height: 58%; background: var(--v3-grad); }
    .v3-intro-photo img { position: relative; z-index: 1; aspect-ratio: 4/3; object-fit: cover; }
    .v3-intro-copy small { color: #38b7a6; font-family: "Montserrat",sans-serif; font-weight: 700; letter-spacing: .2em; }
    .v3-intro-copy h2 { margin-top: 14px; color: var(--v3-navy); font-size: clamp(31px,3.6vw,49px); font-weight: 500; line-height: 1.55; }
    .v3-intro-copy h2 strong { font-weight: 800; }
    .v3-intro-copy p { margin-top: 22px; color: var(--v3-muted); font-size: 13px; line-height: 2.1; }
    .v3-intro-definition { margin-top: 24px; padding: 19px 22px; border-left: 6px solid #45c8a0; background: var(--v3-aqua); color: var(--v3-navy); font-size: 16px; font-weight: 800; line-height: 1.75; }

    .v3-wants { background: var(--v3-aqua); }
    .v3-wants-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
    .v3-want { overflow: hidden; background: #fff; border-radius: 0 0 18px 18px; box-shadow: 0 10px 24px rgba(27,61,81,.08); }
    .v3-want img { aspect-ratio: 1.45/1; object-fit: cover; }
    .v3-want:nth-child(1) img { object-position: center 44%; }
    .v3-want:nth-child(2) img { object-position: center 40%; }
    .v3-want:nth-child(3) img { object-position: center 44%; }
    .v3-want:nth-child(4) img { object-position: center 68%; }
    .v3-want p { display: grid; place-items: center; min-height: 82px; padding: 14px; color: var(--v3-navy); font-size: 14px; font-weight: 700; text-align: center; line-height: 1.65; }

    .v3-problem { background: #fff; }
    .v3-problem-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 28px; }
    .v3-problem-card { position: relative; padding: 34px 28px; border: 1px solid var(--v3-line); background: #fff; text-align: center; }
    .v3-problem-no { display: grid; place-items: center; width: 68px; height: 68px; margin: -68px auto 22px; border: 1px solid #57cbb0; border-radius: 50%; background: #fff; color: #48bba9; font-family: "Montserrat",sans-serif; font-size: 21px; font-weight: 700; }
    .v3-problem-card h3 { color: var(--v3-navy); font-size: 18px; line-height: 1.6; }
    .v3-problem-card p { margin-top: 12px; color: var(--v3-muted); font-size: 11px; line-height: 1.9; }
    .v3-answer { position: relative; margin: 58px auto 0; padding: 28px; background: var(--v3-grad); color: #fff; font-size: clamp(23px,3vw,35px); font-weight: 500; text-align: center; letter-spacing: .08em; }
    .v3-answer::before { content: ""; position: absolute; top: -18px; left: 50%; border: 10px solid transparent; border-bottom-color: var(--v3-blue); transform: translateX(-50%); }
    .v3-answer strong { font-weight: 900; }

    .v3-solution { position: relative; overflow: hidden; background: var(--v3-navy-deep); color: #fff; }
    .v3-solution::before { content: ""; position: absolute; inset: 0; background: linear-gradient(rgba(11,25,45,.7),rgba(11,25,45,.9)),url('/images/gym.jpg') center/cover; }
    .v3-solution .v3-inner { position: relative; }
    .v3-solution .v3-heading h2 { color: #fff; }
    .v3-solution-message { width: min(720px,92%); margin: 0 auto 20px; padding: 20px 24px; border-radius: 18px; background: var(--v3-grad); color: #fff; text-align: center; }
    .v3-solution-message strong { display: block; font-size: clamp(20px,3vw,31px); font-weight: 700; letter-spacing: .08em; }
    .v3-solution-message small { display: block; margin-top: 7px; font-size: 9px; line-height: 1.7; }
    .v3-swipe-hint { margin-bottom: 14px; color: rgba(255,255,255,.82); font-size: 11px; text-align: center; letter-spacing: .1em; }
    .v3-solution-slider { position: relative; }
    .v3-solution-grid { display: flex; gap: 24px; overflow-x: auto; padding: 6px max(15%,calc((100% - 760px)/2)) 18px; scroll-behavior: smooth; scroll-snap-type: x mandatory; scrollbar-width: none; }
    .v3-solution-grid::-webkit-scrollbar { display: none; }
    .v3-solution-card { flex: 0 0 min(760px,70vw); overflow: hidden; border: 7px solid #fff; border-radius: 22px; background: #fff; color: var(--v3-ink); scroll-snap-align: center; box-shadow: 0 18px 40px rgba(0,0,0,.28); }
    .v3-solution-card img { aspect-ratio: 1.85/1; object-fit: cover; }
    .v3-solution-card img.is-nutrition { object-position: 60% center; }
    .v3-solution-copy { min-height: 245px; padding: 30px 34px; text-align: center; }
    .v3-solution-copy small { color: #3fbda4; font-family: "Montserrat",sans-serif; font-size: 11px; font-weight: 700; letter-spacing: .18em; }
    .v3-solution-copy h3 { margin-top: 12px; color: var(--v3-navy); font-size: clamp(22px,3vw,31px); line-height: 1.55; }
    .v3-solution-copy p { max-width: 610px; margin: 15px auto 0; color: var(--v3-muted); font-size: 12px; line-height: 2; }
    .v3-slider-nav { display: flex; align-items: center; justify-content: center; gap: 18px; margin-top: 10px; }
    .v3-slider-nav button { display: grid; place-items: center; width: 46px; height: 46px; border: 1px solid rgba(255,255,255,.72); border-radius: 50%; color: #fff; cursor: pointer; font-size: 20px; }
    .v3-slider-dots { display: flex; gap: 12px; }
    .v3-slider-dots i { width: 9px; height: 9px; border: 1px solid #fff; border-radius: 50%; background: transparent; }
    .v3-slider-dots i.is-active { background: #fff; }

    .v3-reasons { background: #edf4f6; }
    .v3-reason-list { display: grid; gap: 28px; max-width: 980px; margin: auto; }
    .v3-reason { display: grid; grid-template-columns: 1.08fr .92fr; align-items: center; min-height: 430px; overflow: hidden; padding: 34px 42px; border-radius: 26px; background: #fff; box-shadow: 0 12px 30px rgba(26,60,78,.06); }
    .v3-reason:nth-child(even) { grid-template-columns: .92fr 1.08fr; }
    .v3-reason:nth-child(even) .v3-reason-media { order: 2; }
    .v3-reason-media { position: relative; min-height: 330px; }
    .v3-reason-media::before { content: ""; position: absolute; width: 310px; height: 310px; top: 50%; left: 50%; border-radius: 50%; background: var(--v3-grad); transform: translate(-50%,-50%); }
    .v3-reason-media img { position: absolute; z-index: 1; width: 90%; height: 72%; top: 50%; left: 50%; border: 7px solid #fff; object-fit: cover; transform: translate(-50%,-50%); box-shadow: 0 8px 22px rgba(17,42,64,.16); }
    .v3-reason-duo { position: absolute; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 5px; width: 92%; height: 74%; top: 50%; left: 50%; padding: 7px; background: #fff; transform: translate(-50%,-50%); box-shadow: 0 8px 22px rgba(17,42,64,.16); }
    .v3-reason-media .v3-reason-duo img { position: static; width: 100%; height: 100%; border: 0; object-fit: cover; object-position: center 22%; transform: none; box-shadow: none; }
    .v3-reason-media .v3-reason-duo img.is-contest { object-position: center 32%; }
    .v3-reason-media .v3-reason-duo img.is-kaneko-contest { object-position: center 24%; }
    .v3-reason-number { position: absolute; z-index: 2; top: 2px; right: 5px; background: var(--v3-grad); -webkit-background-clip: text; background-clip: text; color: transparent; font-family: "Montserrat",sans-serif; font-size: 68px; font-weight: 600; line-height: .95; }
    .v3-reason-number small { display: block; color: #39b6a9; font-size: 15px; font-weight: 500; letter-spacing: .14em; }
    .v3-reason-copy { display: flex; flex-direction: column; justify-content: center; padding: 30px 20px 30px 36px; }
    .v3-reason:nth-child(even) .v3-reason-copy { padding-right: 36px; padding-left: 20px; }
    .v3-reason-copy small { color: #3bb2a6; font-family: "Montserrat",sans-serif; font-size: 10px; letter-spacing: .2em; }
    .v3-reason-copy h3 { margin-top: 10px; color: var(--v3-navy); font-size: 27px; line-height: 1.6; }
    .v3-reason-copy p { margin-top: 15px; color: var(--v3-muted); font-size: 12px; line-height: 2.05; }

    .v3-comparison { background: var(--v3-aqua); }
    .v3-table-wrap { overflow-x: auto; }
    .v3-scroll-hint { display: none; }
    .v3-table { width: 100%; min-width: 720px; border-collapse: separate; border-spacing: 6px; table-layout: fixed; }
    .v3-table th,.v3-table td { padding: 17px 14px; background: #fff; border: 1px solid #d8e3e6; font-size: 11px; text-align: center; line-height: 1.65; }
    .v3-table thead th { background: var(--v3-navy); color: #fff; font-size: 14px; }
    .v3-table thead th.is-zennu { background: var(--v3-grad); font-size: 18px; }
    .v3-table tbody th { color: var(--v3-navy); font-weight: 800; }
    .v3-table td.is-zennu { border-color: #4bc6a0; background: #f3fff9; color: var(--v3-navy); font-weight: 800; }
    .v3-table-note { margin-top: 13px; color: var(--v3-muted); font-size: 9px; line-height: 1.7; }

    .v3-price { background: #fff; }
    .v3-price-route { margin-bottom: 22px; padding: 20px 24px; border-left: 6px solid #43c6a0; background: var(--v3-aqua); }
    .v3-price-route span { display: block; color: #2eb7aa; font-family: "Montserrat",sans-serif; font-size: 10px; font-weight: 800; letter-spacing: .16em; }
