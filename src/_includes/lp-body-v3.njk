    .v3-solution-card { flex: 0 0 min(760px,70vw); overflow: hidden; border: 7px solid #fff; border-radius: 22px; background: #fff; color: var(--v3-ink); scroll-snap-align: center; box-shadow: 0 18px 40px rgba(0,0,0,.28); }
    .v3-solution-card img { aspect-ratio: 1.85/1; object-fit: cover; }
