    .v3-hero-main, .v3-hero-side > div { overflow: hidden; background: #20344e; }
    .v3-hero-main { clip-path: polygon(12% 0,100% 0,89% 100%,0 100%); margin-left: -11%; }
    .v3-hero-side { display: grid; grid-template-rows: 1fr 1fr; gap: 5px; margin-left: -10%; }
    .v3-hero-media img { height: 100%; object-fit: cover; }
    .v3-hero-main img { object-position: 52% center; }
    .v3-hero-side > div:first-child img { object-position: 75% center; }
    .v3-hero-side > div:last-child img { object-position: 68% center; }
    .v3-hero::before { content: ""; position: absolute; z-index: 1; inset: 72px 0 0; background: linear-gradient(90deg,#10253f 0%,#10253f 34%,rgba(16,37,63,.92) 43%,rgba(16,37,63,.28) 67%,rgba(16,37,63,.12) 100%); }
    .v3-hero-inner { position: relative; z-index: 2; width: min(var(--v3-max), 100%); min-height: 628px; margin: auto; padding: 58px var(--v3-pad) 34px; }
    .v3-hero-copy { width: min(620px, 58%); }
    .v3-hero-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 22px; }
