    .v3-trainer .v3-heading h2 { color: #fff; }
    .v3-trainer .v3-heading p,.v3-trainer .v3-lead { color: rgba(255,255,255,.78); }
    .v3-trainer-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 26px; }
    .v3-trainer-card { position: relative; min-height: 555px; overflow: hidden; border-radius: 0 34px 0 34px; background: #fff; box-shadow: 0 18px 45px rgba(24,56,75,.13); }
    .v3-trainer-ribbons { position: absolute; z-index: 3; top: 24px; left: 0; width: 92%; }
    .v3-trainer-ribbons span { display: block; width: 90%; padding: 12px 22px; background: var(--v3-grad); color: #fff; font-size: 17px; font-weight: 600; letter-spacing: .04em; }
    .v3-trainer-ribbons span + span { width: 100%; margin-top: 8px; }
    .v3-trainer-photo { position: absolute; z-index: 1; top: 0; right: 0; bottom: 0; width: 46%; overflow: hidden; background: #f7f4ef; }
    .v3-trainer-photo > img { height: 100%; object-fit: cover; object-position: center 24%; }
    .v3-certificate { position: absolute; z-index: 2; right: 12px; bottom: 14px; width: 57%; padding: 4px; background: #fff; box-shadow: 0 10px 24px rgba(0,0,0,.23); }
    .v3-certificate img { aspect-ratio: 1.12/1; object-fit: cover; object-position: top; }
    .v3-trainer-copy { position: relative; z-index: 2; width: 58%; padding: 150px 22px 26px; }
    .v3-trainer-copy small { color: #3eb7aa; font-family: "Montserrat",sans-serif; font-size: 9px; letter-spacing: .16em; }
    .v3-trainer-copy h3 { margin-top: 9px; color: var(--v3-navy); font-size: 28px; line-height: 1.45; }
    .v3-trainer-copy h3 span { display: block; margin-bottom: 2px; font-size: 12px; font-weight: 600; }
    .v3-trainer-copy > p { margin-top: 14px; color: var(--v3-muted); font-size: 10px; line-height: 1.9; }
    .v3-trainer-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 16px; }
    .v3-trainer-tags span { padding: 5px 8px; border: 1px solid #56c7b2; color: #299f92; font-size: 8px; font-weight: 700; }
    .v3-trainer-points { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 18px; }
    .v3-trainer-point { display: grid; grid-template-columns: 38px 1fr; gap: 11px; min-height: 112px; padding: 16px 13px; border: 1px solid #cbdde1; background: rgba(255,255,255,.82); }
    .v3-trainer-point.is-wide { grid-column: 1/-1; min-height: 96px; }
    .v3-trainer-point span { display: grid; place-items: center; width: 32px; height: 32px; border-radius: 50%; background: var(--v3-grad); font-weight: 900; }
    .v3-trainer-point strong { font-size: 13px; }
    .v3-trainer-point p { margin-top: 3px; color: var(--v3-muted); font-size: 10px; line-height: 1.7; }
    .v3-trainer-note { margin-top: 12px; color: #7e8997; font-size: 8px; line-height: 1.7; }

    .v3-voice { background: var(--v3-aqua); }
    .v3-voice-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; }
    .v3-voice-card { overflow: hidden; background: #fff; border-radius: 16px; }
    .v3-voice-image { position: relative; }
    .v3-voice-image img { aspect-ratio: 1.35/1; object-fit: cover; }
    .v3-voice-image span { position: absolute; left: 0; bottom: 0; padding: 7px 12px; background: var(--v3-navy); color: #fff; font-size: 9px; font-weight: 800; }
    .v3-voice-body { padding: 22px; }
    .v3-voice-body small { color: #39b7a3; font-size: 9px; font-weight: 800; }
    .v3-voice-body h3 { margin-top: 6px; color: var(--v3-navy); font-size: 18px; }
    .v3-voice-result { display: grid; grid-template-columns: 1fr 1fr; margin-top: 17px; border: 1px solid var(--v3-line); }
    .v3-voice-result div { padding: 12px; text-align: center; }
