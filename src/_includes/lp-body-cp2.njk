  <script src="https://zennuwellnessdesign.hacomono.jp/js/widget.js"></script>
  <script>
    document.querySelectorAll('a[href="#reserve"]').forEach((link) => {
      link.addEventListener('click', () => {
        const ctaLocation = link.closest('.v3-header') ? 'header' : link.closest('.v3-sticky') ? 'sticky' : link.closest('.v3-final') ? 'final' : link.closest('.v3-plan, .v3-ticket') ? 'pricing' : 'section';
        const eventParams = { lp_variant: 'cp2lp', lp_appeal: 'diet', cta_location: ctaLocation };
        if (typeof window.gtag === 'function') window.gtag('event', 'cta_click', eventParams);
        else window.dataLayer.push({ event: 'cta_click', ...eventParams });
        if (typeof window.fbq === 'function') window.fbq('track', 'Contact', { content_name: 'cp2lp_free_trial', content_category: ctaLocation });
      });
    });
  </script>
  <script>
    document.querySelectorAll('.v3-faq-q').forEach((button) => button.addEventListener('click', () => button.closest('.v3-faq-item').classList.toggle('is-open')));
    document.querySelectorAll('.v3-solution-slider').forEach((slider) => {
      const track = slider.querySelector('[data-v3-slider]');
      const cards = [...track.querySelectorAll('.v3-solution-card')];
      const dots = [...slider.querySelectorAll('.v3-slider-dots i')];
      let current = 0;
      const update = (next) => {
        current = Math.max(0, Math.min(cards.length - 1, next));
        track.scrollTo({ left: cards[current].offsetLeft - (track.clientWidth - cards[current].clientWidth) / 2, behavior: 'smooth' });
        dots.forEach((dot, index) => dot.classList.toggle('is-active', index === current));
      };
      slider.querySelector('[data-v3-prev]').addEventListener('click', () => update(current - 1));
      slider.querySelector('[data-v3-next]').addEventListener('click', () => update(current + 1));
      track.addEventListener('scroll', () => {
        const center = track.scrollLeft + track.clientWidth / 2;
        current = cards.reduce((closest, card, index) => Math.abs(card.offsetLeft + card.clientWidth / 2 - center) < Math.abs(cards[closest].offsetLeft + cards[closest].clientWidth / 2 - center) ? index : closest, 0);
        dots.forEach((dot, index) => dot.classList.toggle('is-active', index === current));
      }, { passive: true });
      update(0);
    });
    const sticky = document.getElementById('v3-sticky');
    const reserve = document.getElementById('reserve');
    const updateSticky = () => sticky.classList.toggle('is-hidden', window.scrollY < 320 || reserve.getBoundingClientRect().top < window.innerHeight);
    updateSticky();
    window.addEventListener('scroll', updateSticky, { passive: true });
  </script>
