<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>体重より先に、見た目を変える。| ZenNu WELLNESS DESIGN 熊本</title>
  <meta name="description" content="体重だけにとらわれず、ウエスト・体脂肪率・ラインの変化に向き合う熊本中央区のハイブリッドジム。初回パーソナル体験無料。">
  <link rel="canonical" href="{{ site.meta.url }}/1/">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <meta name="robots" content="noindex, follow">

  <!-- Open Graph / SNSシェア -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="ZenNu WELLNESS DESIGN">
  <meta property="og:title" content="体重より先に、見た目を変える。| ZenNu WELLNESS DESIGN 熊本">
  <meta property="og:description" content="体重だけにとらわれず、ウエスト・体脂肪率・ラインの変化に向き合う熊本中央区のハイブリッドジム。初回パーソナル体験無料。">
  <meta property="og:url" content="{{ site.meta.url }}/1/">
  <meta property="og:image" content="{{ site.meta.url }}{{ site.meta.ogImage }}">
  <meta property="og:locale" content="ja_JP">
  <meta name="twitter:card" content="summary_large_image">

  <!-- 構造化データ（ローカルビジネス / ジム） -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HealthClub",
    "name": "ZenNu WELLNESS DESIGN",
    "description": "{{ site.meta.description }}",
    "url": "{{ site.meta.url }}/",
    "image": "{{ site.meta.url }}{{ site.meta.ogImage }}",
    "telephone": "{{ site.contact.telDisplay }}",
    "priceRange": "¥¥",
    "address": {
      "@type": "PostalAddress",
      "postalCode": "860-0845",
      "addressRegion": "熊本県",
      "addressLocality": "熊本市中央区",
      "streetAddress": "上通町6-15 オークス第二ビル 2F",
      "addressCountry": "JP"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "{{ site.meta.lat }}",
      "longitude": "{{ site.meta.lng }}"
    },
    "openingHoursSpecification": [{
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "07:00",
      "closes": "22:00"
    }]
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800;900&family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
  {% include "site-style.njk" %}
  {% include "variant-style.njk" %}
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-PCDJZ9X9');</script>
  <!-- End Google Tag Manager -->
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PCDJZ9X9" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

{% include "nav.njk" %}

<!-- ─── HERO：体重より見た目 ─── -->
<section class="v1-hero" id="top">
  <div class="v1-hero-photo" aria-hidden="true">
    <img src="/{{ site.hero.image }}" alt="">
  </div>
  <div class="v1-hero-inner">
    <div class="v1-hero-copy">
      <p class="v1-kicker">KUMAMOTO / BODY MAKE STUDIO</p>
      <h1 class="v1-hero-title">体重より先に、<br><em>見た目</em>を変える。</h1>
      <p class="v1-hero-lead">ただ軽くなることが、ゴールではない。<br>鏡を見るたび気になっていたラインに、プロと向き合うボディメイク。</p>
      <div class="v1-hero-actions">
        <a href="#reserve" class="v1-primary-btn">無料体験を予約する<span>→</span></a>
        <p class="v1-hero-note">初回限定・完全無料<br>体験後の入会は任意です</p>
      </div>
    </div>

    <a href="#voice" class="v1-case-card" aria-label="会員様の変化を見る">
      <div class="v1-case-head"><span>REAL MEMBER DATA</span><span>30代女性・3ヶ月</span></div>
      <div class="v1-case-values">
        <div><small>体重</small><strong>-1.6<sup>kg</sup></strong></div>
        <span class="v1-case-divider">でも</span>
        <div class="is-accent"><small>ウエスト</small><strong>-7<sup>cm</sup></strong></div>
      </div>
      <p>産後ダイエット／ADVANCEコースの実例</p>
      <span class="v1-case-link">実例を詳しく見る ↘</span>
    </a>
  </div>
</section>

<!-- ─── FOUNDを参照した実績バッジ ─── -->
<section class="v1-awards" aria-label="ZenNuの実績">
  <div class="v1-awards-inner">
    <div class="v1-awards-intro">
      <span>PROOF, NOT PROMISES.</span>
      <strong>変化を支える、<br>3つの事実。</strong>
    </div>
    {% set v1StatLabels = ["累計指導実績", "3ヶ月の平均変化", "継続率"] %}
    {% set v1StatNotes = ["幅広い年代・目標に対応", "実会員データに基づく", "続けやすさの実績"] %}
    {% for s in site.hero.stats %}
    <div class="v1-award">
      <div class="v1-award-seal">{% include "laurel-svg.njk" %}</div>
      <div class="v1-award-copy">
        <span>{{ v1StatLabels[loop.index0] }}</span>
        <strong><span data-count="{{ s.count }}">{{ s.num }}</span><small>{{ s.unit }}</small></strong>
        <p>{{ v1StatNotes[loop.index0] }}</p>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<!-- ─── INSIGHT ─── -->
<section class="v1-insight" id="concept">
  <div class="v1-section-shell">
    <div class="v1-section-head rv">
      <p class="v1-eyebrow">LOOK BEYOND THE SCALE</p>
      <h2 class="v1-section-title">変えたいのは、<br>体重計の数字だけですか？</h2>
      <p class="v1-section-lead">お腹、二の腕、背中、ヒップライン。気になる場所は人それぞれ。だからZenNuは、体重だけで進捗を判断しません。</p>
    </div>
    <div class="v1-insight-grid stagger">
      <article class="v1-insight-card">
        <span>01 / MEASURE</span>
        <h3>体重だけでなく、<br>変化を多面的に見る。</h3>
        <p>体組成データやウエストの変化、トレーニング中の動きまで確認。数字ひとつに一喜一憂せず、今の体に必要なことを整理します。</p>
      </article>
      <article class="v1-insight-card is-dark">
        <span>02 / DESIGN</span>
        <h3>気になるラインから、<br>やることを決める。</h3>
        <p>目標と現状に合わせて、フォーム・負荷・運動量を調整。自己流で遠回りせず、変えたい場所に向き合えるプログラムをつくります。</p>
      </article>
      <article class="v1-insight-card is-photo">
        <img src="/images/personal2.jpg" alt="トレーナーとフォームを確認する様子" loading="lazy" decoding="async">
        <div><span>03 / CONTINUE</span><h3>教わったことを、<br>自分でも続けられる。</h3></div>
      </article>
    </div>
  </div>
</section>

<!-- ─── REAL MEMBER PROOF ─── -->
<section class="v1-results" id="results">
  <div class="v1-section-shell">
    <div class="v1-section-head rv">
      <p class="v1-eyebrow">REAL MEMBER RESULTS</p>
      <h2 class="v1-section-title">「あまり減っていない」に見えて、<br><em>ラインは変わっている。</em></h2>
      <p class="v1-section-lead">掲載しているのは、ZenNuに通う会員様の実データです。</p>
    </div>
    <div class="v1-result-grid stagger">
      {% for v in site.memberVoice.items %}
      {% if loop.index <= 3 %}
      <article class="v1-result-card">
        <div class="v1-result-image">
          <img src="/{{ v.image }}" alt="{{ v.meta }}のビフォーアフター" loading="lazy" decoding="async">
          <span>{{ v.duration }}</span>
        </div>
        <div class="v1-result-body">
          <p>{{ v.meta }}</p>
          <h3>{{ v.story }}</h3>
          <div class="v1-result-numbers">
            <div><small>体重</small><strong>{{ v.weightKg }}<span>kg</span></strong></div>
            <div><small>体脂肪率</small><strong>{{ v.bodyFatPct }}<span>%</span></strong></div>
            <div class="is-accent"><small>ウエスト</small><strong>{{ v.result }}<span>{{ v.unit }}</span></strong></div>
          </div>
        </div>
      </article>
      {% endif %}
      {% endfor %}
    </div>
    <p class="v1-result-note rv">※ 変化には個人差があります。数値は各会員様の実測データです。</p>
  </div>
</section>

<!-- ─── METHOD ─── -->
<section class="v1-method" id="features">
  <div class="v1-section-shell">
    <div class="v1-method-layout">
      <div class="v1-method-copy rv">
        <p class="v1-eyebrow">HOW ZENNU WORKS</p>
        <h2 class="v1-section-title">パーソナルで学び、<br>セルフで習慣にする。</h2>
        <p class="v1-section-lead">毎回パーソナルに頼るだけでも、一人きりで頑張るだけでもない。プロに軌道修正してもらいながら、自分でも動ける仕組みがZenNuのハイブリッド型です。</p>
        <a href="#price" class="v1-text-link">自分に合うプランを見る <span>→</span></a>
      </div>
      <div class="v1-method-steps stagger">
        <article><span>STEP 01</span><h3>目標と体の状態を整理</h3><p>体験で悩みや理想をヒアリング。今の状態に合わせて、取り組む順番を明確にします。</p></article>
        <article><span>STEP 02</span><h3>パーソナルで正しく覚える</h3><p>フォームや負荷をトレーナーが調整。専用アプリで行ったメニューをいつでも確認できます。</p></article>
        <article><span>STEP 03</span><h3>セルフ利用で回数を重ねる</h3><p>7:00〜22:00、同時4枠の予約制。現在40名／定員80名で、落ち着いて利用しやすい環境です。</p></article>
      </div>
    </div>
    <div class="v1-capacity rv">
      <div><span>SELF TRAINING</span><strong>7:00–22:00</strong><p>同時4枠・現在40名／定員80名</p></div>
      <div><span>PERSONAL TRAINING</span><strong>90 MIN BLOCK</strong><p>9:00–21:00・今月の体験枠 残り{{ site.campaign.remaining }}名様</p></div>
      <a href="#reserve">空き状況を確認する →</a>
    </div>
  </div>
</section>

<!-- ─── CREDENTIAL ─── -->
<section class="v1-credential" id="authority">
  <div class="v1-credential-grid">
    <div class="v1-credential-copy rv">
      <p class="v1-eyebrow">QUALIFIED SUPPORT</p>
      <h2 class="v1-section-title">食事も、感覚だけで<br>アドバイスしない。</h2>
      <p class="v1-section-lead">代表トレーナーは臨床栄養医学指導士。極端な糖質制限やカロリーカットに偏らず、続けやすさを重視して食事を整えます。</p>
      <ul class="v1-credential-list">
        <li><span>01</span><div><strong>資格の知見に基づく食事サポート</strong><p>目的や生活リズムを踏まえ、無理なく見直せるポイントを一緒に整理します。</p></div></li>
        <li><span>02</span><div><strong>運動と食事を同じ担当者に相談</strong><p>トレーニングの進み方と合わせて、必要な方だけ食事管理オプションを選べます。</p></div></li>
        <li><span>03</span><div><strong>実物の資格認定証を掲載</strong><p>認定登録番号549号。画像を開いて実物をご確認いただけます。</p></div></li>
      </ul>
    </div>
    <div class="v1-credential-visual rv">
      <img class="v1-credential-person" src="/images/trainer-mori-credential.png" alt="代表トレーナー 森丈明" loading="lazy" decoding="async">
      <a class="v1-certificate" href="/images/qualification-certificate.png" target="_blank" rel="noopener" aria-label="森丈明の臨床栄養医学指導士 資格認定証を拡大表示">
        <img src="/images/qualification-certificate.png" alt="森丈明 臨床栄養医学指導士 資格認定証 認定登録番号549号" loading="lazy" decoding="async">
        <span><strong>実物の資格認定証</strong><small>拡大して見る ↗</small></span>
      </a>
    </div>
  </div>
</section>

<!-- ─── MID CTA ─── -->
<section class="v1-mid-cta">
  <div class="v1-mid-cta-inner rv">
    <div><span>FREE PERSONAL TRIAL</span><strong>あなたの「気になる」を、<br>体験でトレーナーに聞かせてください。</strong><p>今の体に合わせて、変えるポイントと進め方を整理します。</p></div>
    <a href="#reserve">無料体験を予約する <span>→</span></a>
  </div>
</section>

<!-- ─── COMPARISON（他社比較表）─── -->
<section class="sec-cream" id="comparison">
  <div class="sec-content rv">
    <p class="sec-body" style="max-width:100%; color:#999; font-size:12px; letter-spacing:.2em; margin-bottom:4px;">— WHY ZENNU</p>
    <h3 class="sec-title">「見た目」にこだわる指導は、<br>仕組みからして違います。</h3>
    <div class="comp-table-wrap">
      <table class="comp-table">
        <thead>
          <tr>
            <th></th>
            <th class="th-other">{{ site.comparison.headOther }}</th>
            <th class="th-zen">{{ site.comparison.headZen }}</th>
          </tr>
        </thead>
        <tbody>
          {% for r in site.comparison.rows %}
          <tr><td>{{ r.label }}</td><td>{{ r.other | safe }}</td><td class="td-zen">{{ r.zen | safe }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- ─── TRAINERS ─── -->
<section class="sec-white" id="trainers">
  <div class="sec-big-label rv">TRAINERS</div>
  <div class="sec-big-sub rv">{{ site.trainers.subtitle }}</div>
  <div style="margin-top:48px;">
    {% for t in site.trainers.items %}
    <div class="trainer-row{% if t.reverse %} reverse{% endif %} rv">
      <div class="trainer-panel">
        <div class="trainer-portrait">
          <img src="{{ t.portrait }}" alt="{{ t.jp | striptags }}" loading="lazy" decoding="async">
        </div>
        <div class="trainer-info">
          <div class="trainer-jp">{{ t.jp }}</div>
          <div class="trainer-en">{{ t.en | safe }}</div>
          <p class="trainer-bio">{{ t.bio }}</p>
          <div class="trainer-tags">
            {% for tag in t.tags %}
            <span class="trainer-tag">{{ tag }}</span>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="trainer-action">
        {% if t.actionImage %}
        <img src="{{ t.actionImage }}" alt="{{ t.jp | striptags }} トレーニング" loading="lazy" decoding="async">
        {% else %}
        <div class="trainer-action-ph">
          <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="1.5"/><circle cx="8.5" cy="10" r="1.6"/><path d="M21 16l-5-5L5 19"/></svg>
          <span>COMING SOON</span>
        </div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<!-- ─── GALLERY ─── -->
<section class="sec-cream" id="gallery">
  <div class="sec-big-label rv">GALLERY</div>
  <div class="sec-big-sub rv">{{ site.gallery.subtitle }}</div>
  <div class="sec-content rv">
    <div class="gallery-grid stagger">
      {% for g in site.gallery.items %}
      <div class="g-item{% if g.size %} {{ g.size }}{% endif %}">
        <img src="{{ g.image }}" alt="{{ g.label }}" loading="lazy" decoding="async">
        <span>{{ g.label }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ─── VOICE（Before/After実績・お客様の声）─── -->
<section class="sec-white" id="voice">
  <div class="sec-big-label rv">MEMBER</div>
  <div class="sec-big-sub rv">{{ site.memberVoice.subtitle }}</div>
  <div class="sec-content rv">
    <div class="carousel" id="ba-carousel">
      <button class="car-arrow prev" id="ba-prev" aria-label="前へ">‹</button>
      <div class="car-viewport">
        <div class="car-track" id="ba-track">
          {% for v in site.memberVoice.items %}
          <div class="car-slide">
            <div class="ba-slide-inner">
              <div class="ba-photo"><img src="{{ v.image }}" alt="{{ v.meta }} ビフォーアフター" loading="lazy" decoding="async"></div>
              <div class="ba-info">
                <div class="ba-tag">{{ v.tag }}</div>
                {% if v.story %}
                <div class="ba-meta-row">{{ v.meta }} ／ {{ v.story }}</div>
                {% else %}
                <div class="ba-meta-row">{{ v.meta }}</div>
                {% endif %}

                <div class="ba-stats">
                  {% if v.duration and v.weightKg %}
                  <div class="ba-stat-main">
                    <span class="ba-stat-pre">{{ v.duration }}</span>
                    <span class="ba-stat-num">{{ v.weightKg }}<span>kg</span></span>
                  </div>
                  {% endif %}
                  <div class="ba-stat-sub">
                    <div><span class="ba-stat-sub-label">ウエスト</span><span class="ba-stat-sub-num">{{ v.result }}<i>{{ v.unit }}</i></span></div>
                    {% if v.bodyFatPct %}
                    <div><span class="ba-stat-sub-label">体脂肪率</span><span class="ba-stat-sub-num">{{ v.bodyFatPct }}<i>%</i></span></div>
                    {% endif %}
                  </div>
                </div>

                {% if v.journey or v.currentRoutine %}
                <div class="ba-routine">
                  {% if v.journey %}
                  <div class="ba-journey">
                    <div class="ba-block-title">通い方の変化</div>
                    <ol class="ba-journey-list">
                      {% for step in v.journey %}
                      <li><span class="ba-journey-num">{{ "0" + loop.index if loop.index < 10 else loop.index }}</span>{{ step }}</li>
                      {% endfor %}
                    </ol>
                  </div>
                  {% endif %}
                  {% if v.currentRoutine %}
                  <div class="ba-current">
                    <div class="ba-block-title">現在の通い方</div>
                    <div class="ba-current-box">
                      {% for line in v.currentRoutine %}
                      <div>{{ line }}</div>
                      {% endfor %}
                    </div>
                  </div>
                  {% endif %}
                </div>
                {% endif %}

                <p class="ba-quote">{{ v.quote }}</p>
                <div class="ba-who">{{ v.who }}</div>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      <button class="car-arrow next" id="ba-next" aria-label="次へ">›</button>
    </div>
    <div class="car-dots" id="ba-dots"></div>
  </div>
</section>

<!-- ─── PRICE ─── -->
<section class="sec-cream" id="price">
  <div class="sec-big-label rv">PRICE</div>
  <div class="sec-big-sub rv" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <span>{{ site.pricing.subtitle }}</span>
    <a href="#cta" style="font-family:var(--display);font-weight:700;font-size:13px;letter-spacing:.08em;color:var(--orange);border-bottom:1px solid var(--orange);padding-bottom:2px;">
      まずは無料体験から →
    </a>
  </div>
  <div class="sec-content rv">
    <div class="price-grid stagger">
      {% for p in site.pricing.plans %}
      <div class="plan-card{% if p.popular %} popular{% endif %}">
        {% if p.popular %}<span class="popular-tag">MOST POPULAR</span>{% endif %}
        <div class="plan-top">
          <div class="plan-name">{{ p.name }}</div>
          <div class="plan-for">{{ p.for }}</div>
        </div>
        <div class="plan-body">
          <div class="plan-price">{{ p.price }}<span class="unit">{{ p.unit }}</span></div>
          <div class="plan-items">
            {% if p.name == "LIGHT" %}
            <div class="plan-item">セルフトレーニング使い放題</div>
            <div class="plan-item">トレーナー常駐（随時相談OK）</div>
            <div class="plan-item">同時4枠の予約制で快適な環境</div>
            {% elif p.name == "STANDARD" %}
            <div class="plan-item">セルフトレーニング使い放題</div>
            <div class="plan-item">パーソナル指導 月2回</div>
            <div class="plan-item">トレーナー常駐（随時相談OK）</div>
            <div class="plan-item">同時4枠の予約制で快適な環境</div>
            {% else %}
            {% for it in p.items %}<div class="plan-item">{{ it }}</div>{% endfor %}
            {% endif %}
          </div>
          <a href="#cta" class="plan-cta">体験する</a>
        </div>
      </div>
      {% endfor %}
    </div>
    <div class="ticket-block rv">
      <div class="ticket-head">
        <div class="ticket-title">{{ site.pricing.ticket.title }}</div>
        <div class="ticket-sub">{{ site.pricing.ticket.sub }}</div>
      </div>
      <div class="ticket-grid stagger">
        {% for c in site.pricing.ticket.cards %}
        <div class="ticket-card{% if c.best %} best{% endif %} {{ 'tilt-l' if loop.first else 'tilt-r' }}">
          {% if c.badge %}<span class="ticket-badge">{{ c.badge }}</span>{% endif %}
          <div class="ticket-count">{{ c.count }}<span>回</span></div>
          <div class="ticket-price">{{ c.price }}</div>
          <div class="ticket-per">{{ c.per }}</div>
        </div>
        {% endfor %}
      </div>
    </div>

    <div class="addon-grid stagger">
      {% for a in site.pricing.addons %}
      <div class="addon-box {{ 'tilt-l' if loop.first else 'tilt-r' }}">
        <div class="addon-head{% if a.dark %} dark{% endif %}">{{ a.title }} <small>{{ a.en }}</small></div>
        <p class="addon-desc">{{ a.desc }}</p>
        <div class="addon-lines">
          {% for l in a.lines %}
          <div class="addon-line"><span>{{ l.label }}</span><strong>{{ l.price }}<small>{{ l.per }}</small></strong></div>
          {% endfor %}
        </div>
        <p class="addon-note">{{ a.note | safe }}</p>
      </div>
      {% endfor %}
    </div>

    <p class="price-note rv">{{ site.pricing.note | safe }}</p>
  </div>
</section>

<!-- ─── FLOW ─── -->
<section class="sec-white">
  <div class="sec-big-label rv">FLOW</div>
  <div class="sec-big-sub rv">{{ site.flow.subtitle }}</div>
  <div class="sec-content rv">
    <div class="flow-grid stagger">
      {% for step in site.flow.steps %}
      <div class="flow-step{% if step.accent %} accent{% endif %}">
        <div class="flow-num">{{ step.num }}</div>
        <div class="flow-title">{{ step.title }}</div>
        <div class="flow-desc">{{ step.desc }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ─── FAQ ─── -->
<section class="sec-cream" id="faq">
  <div class="sec-big-label rv">FAQ</div>
  <div class="sec-big-sub rv">{{ site.faq.subtitle }}</div>
  <div class="sec-content rv">
    <div class="faq-grid">
      {% for item in site.faq.items %}
      <div class="faq-item">
        <button class="faq-q">
          <span class="faq-q-mark">Q</span>
          <span class="faq-q-text">{{ item.q }}</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-a"><div class="faq-a-inner">
          <p>{{ item.a }}</p>
        </div></div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ─── STORE INFO ─── -->
<section class="sec-white" id="access">
  <div class="sec-big-label rv">INFO</div>
  <div class="sec-big-sub rv">店舗情報・アクセス</div>
  <div class="sec-content rv">
    <div class="access-grid">
      <div class="access-map">
        <iframe title="ZenNu WELLNESS DESIGN 地図" src="{{ site.access.mapEmbed }}" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
      <div class="info-list">
        {% for row in site.access.rows %}
        <div class="info-row">
          <div class="info-label">{{ row.label }}</div>
          <div class="info-value">{{ row.value | safe }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- ─── CTA (campaign) ─── -->
<section class="camp" id="cta">
  <div class="camp-bg" style="background-image:url('/images/hero.jpg');"></div>
  <div class="camp-inner rv">
    <div class="camp-ribbon">{{ site.cta.campaignTitle }}</div>
    <p class="camp-sub">{{ site.cta.title }}</p>

    <div class="camp-benefits">
      {% for b in site.cta.benefits %}
      <div class="camp-card">
        <span class="camp-no">特典<strong>{{ b.no }}</strong></span>
        <div class="camp-card-lead">{{ b.lead }}</div>
        <div class="camp-deal">
          <span class="camp-before">{{ b.before }}</span>
          <span class="camp-arrow">▶</span>
          <span class="camp-after">{{ b.after }}</span>
        </div>
      </div>
      {% endfor %}

      <div class="camp-card camp-gift">
        <span class="camp-no">特典<strong>{{ site.cta.gift.no }}</strong></span>
        <div class="camp-gift-body">
          {% if site.cta.gift.image %}
          <div class="camp-gift-img"><img src="{{ site.cta.gift.image }}" alt="体組成計レポート見本" loading="lazy" decoding="async"></div>
          {% endif %}
          <div class="camp-gift-text">
            <div class="camp-gift-lead">{{ site.cta.gift.lead }}</div>
            <h3 class="camp-gift-title">{{ site.cta.gift.title }}</h3>
            <ul class="camp-gift-list">
              {% for g in site.cta.gift.items %}
              <li>{{ g | safe }}</li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="camp-foot">
      <div class="camp-limit">先着順！今月の体験予約枠 残り{{ site.campaign.remaining }}名様</div>
      <a href="#reserve" class="camp-btn">
        <span class="camp-btn-tag">手ぶらOK</span>
        <span class="camp-btn-main">無料体験を予約する</span>
        <span class="camp-btn-arr">→</span>
      </a>
      <p class="camp-note">{{ site.cta.note }}</p>
      <div class="camp-scroll">{{ site.cta.scroll }} ↓</div>
    </div>
  </div>
</section>

<!-- ─── RESERVATION (hacomono) ─── -->
<section class="sec-white" id="reserve">
  <div class="sec-content rv" style="padding-top: clamp(36px, 5vw, 60px);">
    <div class="reserve-widget">
      <iframe id="hacomono-widget-w0002" src="https://zennuwellnessdesign.hacomono.jp/widgets/2?isFilterableByCategory=false&isShowStudioInfo=true&studioIds=1" title="ZenNu 予約ウィジェット"></iframe>
    </div>
  </div>
</section>
<script src="https://zennuwellnessdesign.hacomono.jp/js/widget.js"></script>

<!-- ─── FOOTER ─── -->
{% include "footer.njk" %}

<!-- sticky -->
<div class="sticky-bar" id="sticky-bar">
  <a href="#reserve">無料体験を予約する（今月残り{{ site.campaign.remaining }}名） →</a>
</div>

<script>
  // header scroll
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  // hamburger
  const hamBtn = document.getElementById('ham-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  hamBtn.addEventListener('click', () => {
    const open = hamBtn.classList.toggle('active');
    mobileMenu.classList.toggle('open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  });
  document.querySelectorAll('.nav-link').forEach(l => {
    l.addEventListener('click', () => {
      hamBtn.classList.remove('active');
      mobileMenu.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  // FAQ
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  });

  // sticky bar
  const stickyBar = document.getElementById('sticky-bar');
  const ctaSec = document.getElementById('cta');
  const footer = document.querySelector('.site-footer');
  window.addEventListener('scroll', () => {
    const ct = ctaSec.getBoundingClientRect().top;
    const ft = footer.getBoundingClientRect().top;
    stickyBar.classList.toggle('hide', ct < window.innerHeight || ft < window.innerHeight + 60);
  }, { passive: true });

  // scroll reveal + stagger
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('on'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.06, rootMargin: '0px 0px -20px 0px' });
  document.querySelectorAll('.rv, .stagger').forEach(el => obs.observe(el));

  // stats count-up
  const countObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      countObs.unobserve(e.target);
      const to = parseInt(e.target.dataset.count, 10);
      const dur = 1300, start = performance.now();
      const tick = now => {
        const p = Math.min((now - start) / dur, 1);
        const ease = 1 - Math.pow(1 - p, 3);
        e.target.textContent = Math.round(to * ease);
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('[data-count]').forEach(el => countObs.observe(el));

  // before/after carousel
  (() => {
    const track = document.getElementById('ba-track');
    if (!track) return;
    const slides = track.querySelectorAll('.car-slide');
    const prev = document.getElementById('ba-prev');
    const next = document.getElementById('ba-next');
    const dotsWrap = document.getElementById('ba-dots');
    let index = 0;

    slides.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.className = 'car-dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('aria-label', (i + 1) + '番目を表示');
      dot.addEventListener('click', () => goTo(i));
      dotsWrap.appendChild(dot);
    });
    const dots = dotsWrap.querySelectorAll('.car-dot');

    function goTo(i) {
      index = (i + slides.length) % slides.length;
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((d, di) => d.classList.toggle('active', di === index));
    }
    prev.addEventListener('click', () => goTo(index - 1));
    next.addEventListener('click', () => goTo(index + 1));

    // swipe support
    let startX = null;
    const vp = track.parentElement;
    vp.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
    vp.addEventListener('touchend', e => {
      if (startX === null) return;
      const dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 40) goTo(index + (dx < 0 ? 1 : -1));
      startX = null;
    }, { passive: true });
  })();
</script>
</body>
</html>
