      .v3-proof-crown { top: 6px; font-size: 14px; }
      .v3-hero-proof small { font-size: 6px; letter-spacing: .04em; }
      .v3-hero-proof strong { font-size: 16px; }
      .v3-hero-proof strong span { display: block; margin-top: 1px; font-size: 8px; }
      .v3-proof-stars { font-size: 6px; }
      .v3-hero-proof-note { max-width: 310px; margin: 8px auto 0; font-size: 6px; line-height: 1.55; text-align: center; }
      .v3-offer-inner { padding: 20px; }
      .v3-offer-message { gap: 12px; }
      .v3-offer-icon { flex-basis: 70px; height: 70px; font-size: 11px; }
      .v3-offer-message p { font-size: 13px; }
      .v3-offer-limit { left: 2%; right: 2%; font-size: 9px; }
      .v3-offer-btn { min-height: 66px; padding: 13px 12px; font-size: 14px; }
      .v3-offer-btn span { width: 40px; height: 40px; font-size: 8px; }
      .v3-offer-btn b { font-size: 18px; }
      .v3-section { padding: 66px 20px; }
      .v3-heading { margin-bottom: 36px; }
      .v3-heading h2 { font-size: 29px; letter-spacing: .03em; }
      .v3-lead { font-size: 11px; }
      .v3-intro-grid { gap: 34px; }
      .v3-intro-photo::before { top: -10px; left: -10px; }
      .v3-intro-copy h2 { font-size: 30px; }
      .v3-intro-copy p { font-size: 11px; }
      .v3-intro-definition { font-size: 13px; }
      .v3-wants-grid { gap: 9px; }
      .v3-want p { min-height: 74px; padding: 10px; font-size: 11px; }
      .v3-problem-grid { gap: 50px; }
      .v3-problem-card { padding: 32px 20px 24px; }
      .v3-answer { margin-top: 40px; padding: 22px 14px; font-size: 20px; }
      .v3-solution-message { width: 100%; padding: 17px 14px; }
      .v3-solution-grid { gap: 14px; margin: 0 -20px; padding: 6px 38px 18px; }
      .v3-solution-card { flex-basis: calc(100vw - 76px); border-width: 5px; border-radius: 16px; }
      .v3-solution-card img { aspect-ratio: 1.25/1; }
      .v3-solution-copy { min-height: 340px; padding: 25px 21px; }
      .v3-solution-copy h3 { font-size: 22px; }
      .v3-solution-copy p { font-size: 11px; }
      .v3-reason,.v3-reason:nth-child(even) { grid-template-columns: 1fr; padding: 22px 16px 28px; border-radius: 18px; }
      .v3-reason-media { min-height: 200px; }
      .v3-reason-media::before { width: 220px; height: 220px; }
      .v3-reason-media img { width: 88%; height: 72%; border-width: 5px; }
      .v3-reason-number { top: -2px; font-size: 53px; }
      .v3-reason-number small { font-size: 11px; }
      .v3-reason-copy,.v3-reason:nth-child(even) .v3-reason-copy { padding: 20px 10px 0; }
      .v3-reason-copy h3 { font-size: 20px; }
      .v3-plan-grid { gap: 15px; }
      .v3-ticket-grid { grid-template-columns: 1fr; }
