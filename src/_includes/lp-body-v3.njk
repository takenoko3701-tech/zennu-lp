      --v3-gold-light: #fff0b4;
      --v3-ink: #17243a;
      --v3-muted: #657082;
      --v3-line: #d5e1e5;
      --v3-white: #fff;
      --v3-max: 1160px;
      --v3-pad: clamp(20px, 4.8vw, 64px);
