      .v3-reason-copy,.v3-reason:nth-child(even) .v3-reason-copy { padding: 24px; }
      .v3-plan-grid { grid-template-columns: 1fr; }
      .v3-plan-items { min-height: 0; }
      .v3-trainer-cards { grid-template-columns: 1fr; max-width: 650px; margin: auto; }
      .v3-trainer-card { min-height: 540px; }
      .v3-voice-grid { max-width: 650px; margin: auto; }
      .v3-flow-grid { grid-template-columns: 1fr; max-width: 680px; margin-right: auto; margin-left: auto; }
      .v3-access-grid { grid-template-columns: 1fr; }
      .v3-access-map iframe { min-height: 390px; }
    }

    @media (max-width: 640px) {
      .v3-header { height: 62px; }
      .v3-header-inner { gap: 10px; padding: 0 14px; }
      .v3-logo { min-width: 0; }
      .v3-logo img { width: min(42vw,158px); }
      .v3-header-cta { flex-shrink: 0; padding: 10px 12px; font-size: 10px; box-shadow: 0 4px 0 var(--v3-orange-dark); }
      .v3-header-cta i { display: none; }
      .v3-hero { min-height: 0; padding-top: 62px; }
      .v3-hero-media { position: relative; inset: auto; z-index: 0; grid-template-columns: 1.14fr .86fr; height: 214px; gap: 3px; opacity: 1; }
      .v3-hero-main { clip-path: none; margin: 0; }
      .v3-hero-side { display: grid; gap: 3px; margin: 0; }
      .v3-hero-media img { filter: saturate(.9) contrast(1.04); }
      .v3-hero::before { inset: 62px 0 auto; height: 214px; background: linear-gradient(180deg,rgba(11,25,45,.08),rgba(11,25,45,.48)); }
      .v3-hero-inner { min-height: 0; padding: 0 20px 22px; background: var(--v3-navy-deep); }
      .v3-hero-copy { width: 100%; }
      .v3-hero-tags { position: relative; z-index: 3; gap: 4px; margin: -17px 0 12px; }
      .v3-hero-tags span { min-width: 0; flex: 1; padding: 7px 3px; font-size: 8px; }
      .v3-hero-kicker { margin-bottom: 2px; font-size: 11px; letter-spacing: .09em; }
      .v3-hero-title { font-size: clamp(31px,9vw,37px); line-height: 1.28; }
      .v3-hero-sub { margin-top: 4px; font-size: clamp(17px,5.3vw,21px); line-height: 1.45; letter-spacing: .02em; }
      .v3-hero-lead { display: none; }
      .v3-price-label { width: 39px; height: 66px; font-size: 8px; }
      .v3-hero-price { gap: 8px; margin-top: 10px; }
      .v3-hero-price small { margin-bottom: 4px; font-size: 11px; }
      .v3-hero-price strong { font-size: 47px; }
      .v3-hero-price b { padding-bottom: 5px; font-size: 17px; }
      .v3-hero-note { margin-top: 6px; font-size: 8px; }
      .v3-hero-proof { grid-template-columns: repeat(3,minmax(0,88px)); justify-content: center; gap: 10px; margin-top: 13px; }
      .v3-proof-medal { width: 88px; padding: 21px 3px 10px; }
      .v3-proof-medal::before,.v3-proof-medal::after { top: 26%; width: 12px; height: 52%; }
      .v3-proof-medal::before { left: -6px; }
