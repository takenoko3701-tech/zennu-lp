      .v3-trainer::before { height: 330px; }
      .v3-trainer .v3-heading { margin-bottom: 48px; }
      .v3-trainer-cards { gap: 18px; }
      .v3-trainer-card { min-height: 0; padding-top: 106px; border-radius: 0 24px 0 24px; }
      .v3-trainer-ribbons { top: 20px; width: 96%; }
      .v3-trainer-ribbons span { padding: 10px 16px; font-size: 15px; }
      .v3-trainer-photo { position: relative; width: 100%; height: 340px; }
      .v3-trainer-photo > img { object-position: center 20%; }
      .v3-certificate { right: 10px; bottom: 10px; width: 42%; padding: 3px; }
