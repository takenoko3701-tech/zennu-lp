<!-- ─── HEADER ─── -->
<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="#top" class="site-logo">
      <img src="images/logo-yoko.png" alt="ZenNu WELLNESS DESIGN" class="logo-img">
    </a>

    <nav class="site-nav">
      <a href="#concept">コンセプト</a>
      <a href="#trainers">トレーナー</a>
      <a href="#gallery">館内</a>
      <a href="#price">料金</a>
      <a href="#faq">FAQ</a>
      <a href="#access">店舗情報</a>
    </nav>

    <a href="#reserve" class="header-cta">無料体験を予約</a>

    <button class="ham-btn" id="ham-btn" aria-label="メニュー">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- mobile menu -->
<nav class="mobile-menu" id="mobile-menu">
  <ul>
    <li><a href="#concept" class="nav-link">コンセプト</a></li>
    <li><a href="#trainers" class="nav-link">トレーナー</a></li>
    <li><a href="#gallery" class="nav-link">館内ギャラリー</a></li>
    <li><a href="#features" class="nav-link">特徴</a></li>
    <li><a href="#price" class="nav-link">料金</a></li>
    <li><a href="#faq" class="nav-link">FAQ</a></li>
    <li><a href="#access" class="nav-link">店舗情報</a></li>
  </ul>
  <a href="#reserve" class="mobile-cta nav-link">無料体験を予約する</a>
</nav>

<!-- ─── HERO ─── -->
<section class="hero" id="top">
  <!-- photo layer (lower-right, behind text) -->
  <div class="hero-photo">
    <div class="hero-photo-img">
      <img src="{{ site.hero.image }}" alt="ZenNu パーソナルトレーニング">
    </div>
    <a href="#reserve" class="hero-reserve">
      <span class="reserve-jp">予約する</span>
      <span class="reserve-en">RESERVATION</span>
    </a>
  </div>

  <!-- text layer (on top of photo) -->
  <div class="hero-inner">
    <div class="hero-eyebrow">{{ site.hero.eyebrow }}</div>
    <h1 class="hero-headline">{{ site.hero.headline | safe }}</h1>
    <div class="hero-bottom">
      <div>
        <p class="hero-jp">{{ site.hero.jp }}</p>
        <p class="hero-desc">{{ site.hero.desc }}</p>
        <div class="hero-btns">
          <a href="#cta" class="btn-orange">無料体験を予約する<span class="arr"></span></a>
          <a href="#concept" class="btn-ghost">ZenNuについて知る</a>
        </div>
      </div>
      <div class="hero-stats">
        {% for s in site.hero.stats %}
        <div>
          <div class="hs-num"><span data-count="{{ s.count }}">{{ s.num }}</span><span>{{ s.unit }}</span></div>
          <div class="hs-lbl">{{ s.label }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- ─── BAND ─── -->
<div class="band">
  <p>{{ site.campaign.bandText }}</p>
</div>

<!-- ─── INTRO (second view) ─── -->
<section class="intro" id="about">
  <div class="intro-inner">
    <div class="intro-head rv">
      <div class="intro-en">{{ site.intro.en | safe }}</div>
      <div class="intro-en-sub">{{ site.intro.enSub }}</div>
    </div>
    <div class="intro-body">
      <div class="intro-visual rv">
        <div class="intro-main">
          <img src="{{ site.intro.mainImage }}" alt="ZenNu パーソナルトレーニング" loading="lazy" decoding="async">
        </div>
        <div class="intro-staff">
          <img src="{{ site.intro.staffImage }}" alt="ZenNu 受付" loading="lazy" decoding="async">
        </div>
      </div>
      <div class="intro-text rv">
        <div class="intro-text-label">{{ site.intro.label }}</div>
        <p class="intro-text-lead">{{ site.intro.lead | safe }}</p>
        <p class="intro-text-body">{{ site.intro.body | safe }}</p>
        <a href="#concept" class="intro-text-link">{{ site.intro.linkText }}<span>→</span></a>
      </div>
    </div>
  </div>
</section>

<!-- ─── CONCEPT ─── -->
<section class="sec-white" id="concept">
  <div class="sec-big-label rv">CONCEPT</div>
  <div class="sec-big-sub rv">{{ site.concept.subtitle }}</div>
  <div class="sec-content rv">
    <p class="concept-intro">{{ site.concept.intro | safe }}</p>
    <div class="concept-cards stagger">
      {% for c in site.concept.cards %}
      <div class="ccard">
        <div class="ccard-img">
          <span class="ccard-num">{{ c.num }}</span>
          <img src="{{ c.image }}" alt="{{ c.title | striptags }}" loading="lazy" decoding="async">
        </div>
        <h3 class="ccard-title">{{ c.title | safe }}</h3>
        <p class="ccard-text">{{ c.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- comparison -->
  <div class="sec-content rv" style="padding-top:0;">
    <p class="sec-body" style="max-width:100%; color:#999; font-size:12px; letter-spacing:.2em; margin-bottom:4px;">{{ site.comparison.eyebrow }}</p>
    <h3 class="sec-title">{{ site.comparison.title }}</h3>
    <div class="comp-table-wrap">
      <table class="comp-table">
        <thead>
          <tr>
            <th></th>
            <th class="th-other">{{ site.comparison.headOther }}</th>
            <th class="th-zen">{{ site.comparison.headZen }}</th>
          </tr>
        </thead>
        <tbody>
          {% for r in site.comparison.rows %}
          <tr><td>{{ r.label }}</td><td>{{ r.other | safe }}</td><td class="td-zen">{{ r.zen | safe }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- ─── FEATURES ─── -->
<section class="sec-cream" id="features">
  <div class="sec-big-label rv">FEATURES</div>
  <div class="sec-big-sub rv">{{ site.features.subtitle }}</div>
  <div class="sec-content rv">
    <div class="features-grid stagger">
      {% for f in site.features.items %}
      <div class="feat-card" data-num="{{ f.num }}">
        <h3 class="feat-title">{{ f.title }}</h3>
        <p class="feat-body">{{ f.body }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ─── TRAINERS ─── -->
<section class="sec-white" id="trainers">
  <div class="sec-big-label rv">TRAINERS</div>
  <div class="sec-big-sub rv">{{ site.trainers.subtitle }}</div>
  <div style="margin-top:48px;">
    {% for t in site.trainers.items %}
    <div class="trainer-row{% if t.reverse %} reverse{% endif %} rv">
      <div class="trainer-panel">
        <div class="trainer-portrait">
          <img src="{{ t.portrait }}" alt="{{ t.jp | striptags }}" loading="lazy" decoding="async">
        </div>
        <div class="trainer-info">
          <div class="trainer-jp">{{ t.jp }}</div>
          <div class="trainer-en">{{ t.en | safe }}</div>
          <p class="trainer-bio">{{ t.bio }}</p>
          <div class="trainer-tags">
            {% for tag in t.tags %}
            <span class="trainer-tag">{{ tag }}</span>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="trainer-action">
        {% if t.actionImage %}
        <img src="{{ t.actionImage }}" alt="{{ t.jp | striptags }} トレーニング" loading="lazy" decoding="async">
        {% else %}
        <div class="trainer-action-ph">
          <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="1.5"/><circle cx="8.5" cy="10" r="1.6"/><path d="M21 16l-5-5L5 19"/></svg>
          <span>COMING SOON</span>
        </div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<!-- ─── GALLERY ─── -->
<section class="sec-cream" id="gallery">
  <div class="sec-big-label rv">GALLERY</div>
  <div class="sec-big-sub rv">{{ site.gallery.subtitle }}</div>
  <div class="sec-content rv">
    <div class="gallery-grid stagger">
      {% for g in site.gallery.items %}
      <div class="g-item{% if g.size %} {{ g.size }}{% endif %}">
        <img src="{{ g.image }}" alt="{{ g.label }}" loading="lazy" decoding="async">
        <span>{{ g.label }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ─── VOICE ─── -->
<section class="sec-white" id="voice">
  <div class="sec-big-label rv">MEMBER</div>
  <div class="sec-big-sub rv">{{ site.memberVoice.subtitle }}</div>
  <div class="sec-content rv">
    <div class="carousel" id="ba-carousel">
      <button class="car-arrow prev" id="ba-prev" aria-label="前へ">‹</button>
      <div class="car-viewport">
        <div class="car-track" id="ba-track">
          {% for v in site.memberVoice.items %}
          <div class="car-slide">
            <div class="ba-slide-inner">
              <div class="ba-photo"><img src="{{ v.image }}" alt="{{ v.meta }} ビフォーアフター" loading="lazy" decoding="async"></div>
              <div class="ba-info">
                <div class="ba-tag">{{ v.tag }}</div>
                <div class="ba-result">{{ v.result }}<span>{{ v.unit }}</span></div>
                <div class="ba-result-label">{{ v.label }}</div>
                <div class="ba-meta">{{ v.meta }}</div>
                <p class="ba-quote">{{ v.quote }}</p>
                <div class="ba-who">{{ v.who }}</div>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      <button class="car-arrow next" id="ba-next" aria-label="次へ">›</button>
    </div>
    <div class="car-dots" id="ba-dots"></div>
  </div>
</section>

<!-- ─── FLOW ─── -->
<section class="sec-cream">
  <div class="sec-big-label rv">FLOW</div>
  <div class="sec-big-sub rv">{{ site.flow.subtitle }}</div>
  <div class="sec-content rv">
    <div class="flow-grid stagger">
      {% for step in site.flow.steps %}
      <div class="flow-step{% if step.accent %} accent{% endif %}">
        <div class="flow-num">{{ step.num }}</div>
        <div class="flow-title">{{ step.title }}</div>
        <div class="flow-desc">{{ step.desc }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ─── PRICE ─── -->
<section class="sec-white" id="price">
  <div class="sec-big-label rv">PRICE</div>
  <div class="sec-big-sub rv" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <span>{{ site.pricing.subtitle }}</span>
    <a href="#cta" style="font-family:var(--display);font-weight:700;font-size:13px;letter-spacing:.08em;color:var(--orange);border-bottom:1px solid var(--orange);padding-bottom:2px;">
      まずは無料体験から →
    </a>
  </div>
  <div class="sec-content rv">
    <div class="price-grid stagger">
      {% for p in site.pricing.plans %}
      <div class="plan-card{% if p.popular %} popular{% endif %}">
        {% if p.popular %}<span class="popular-tag">MOST POPULAR</span>{% endif %}
        <div class="plan-top">
          <div class="plan-name">{{ p.name }}</div>
          <div class="plan-for">{{ p.for }}</div>
        </div>
        <div class="plan-body">
          <div class="plan-price">{{ p.price }}<span class="unit">{{ p.unit }}</span></div>
          <div class="plan-items">
            {% for it in p.items %}
            <div class="plan-item">{{ it }}</div>
            {% endfor %}
          </div>
          <a href="#cta" class="plan-cta">体験する</a>
        </div>
      </div>
      {% endfor %}
    </div>
    <div class="ticket-block rv">
      <div class="ticket-head">
        <div class="ticket-title">{{ site.pricing.ticket.title }}</div>
        <div class="ticket-sub">{{ site.pricing.ticket.sub }}</div>
      </div>
      <div class="ticket-grid stagger">
        {% for c in site.pricing.ticket.cards %}
        <div class="ticket-card{% if c.best %} best{% endif %} {{ 'tilt-l' if loop.first else 'tilt-r' }}">
          {% if c.badge %}<span class="ticket-badge">{{ c.badge }}</span>{% endif %}
          <div class="ticket-count">{{ c.count }}<span>回</span></div>
          <div class="ticket-price">{{ c.price }}</div>
          <div class="ticket-per">{{ c.per }}</div>
        </div>
        {% endfor %}
      </div>
    </div>

    <div class="addon-grid stagger">
      {% for a in site.pricing.addons %}
      <div class="addon-box {{ 'tilt-l' if loop.first else 'tilt-r' }}">
        <div class="addon-head{% if a.dark %} dark{% endif %}">{{ a.title }} <small>{{ a.en }}</small></div>
        <p class="addon-desc">{{ a.desc }}</p>
        <div class="addon-lines">
          {% for l in a.lines %}
          <div class="addon-line"><span>{{ l.label }}</span><strong>{{ l.price }}<small>{{ l.per }}</small></strong></div>
          {% endfor %}
        </div>
        <p class="addon-note">{{ a.note | safe }}</p>
      </div>
      {% endfor %}
    </div>

    <p class="price-note rv">{{ site.pricing.note | safe }}</p>
  </div>
</section>

<!-- ─── FAQ ─── -->
<section class="sec-cream" id="faq">
  <div class="sec-big-label rv">FAQ</div>
  <div class="sec-big-sub rv">{{ site.faq.subtitle }}</div>
  <div class="sec-content rv">
    <div class="faq-grid">
      {% for item in site.faq.items %}
      <div class="faq-item">
        <button class="faq-q">
          <span class="faq-q-mark">Q</span>
          <span class="faq-q-text">{{ item.q }}</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-a"><div class="faq-a-inner">
          <p>{{ item.a }}</p>
        </div></div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ─── STORE INFO ─── -->
<section class="sec-white" id="access">
  <div class="sec-big-label rv">INFO</div>
  <div class="sec-big-sub rv">店舗情報・アクセス</div>
  <div class="sec-content rv">
    <div class="access-grid">
      <div class="access-map">
        <iframe title="ZenNu WELLNESS DESIGN 地図" src="{{ site.access.mapEmbed }}" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
      <div class="info-list">
        {% for row in site.access.rows %}
        <div class="info-row">
          <div class="info-label">{{ row.label }}</div>
          <div class="info-value">{{ row.value | safe }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- ─── CTA (campaign) ─── -->
<section class="camp" id="cta">
  <div class="camp-bg" style="background-image:url('images/hero.jpg');"></div>
  <div class="camp-inner rv">
    <div class="camp-ribbon">{{ site.cta.campaignTitle }}</div>
    <p class="camp-sub">{{ site.cta.title }}</p>

    <div class="camp-benefits">
      {% for b in site.cta.benefits %}
      <div class="camp-card">
        <span class="camp-no">特典<strong>{{ b.no }}</strong></span>
        <div class="camp-card-lead">{{ b.lead }}</div>
        <div class="camp-deal">
          <span class="camp-before">{{ b.before }}</span>
          <span class="camp-arrow">▶</span>
          <span class="camp-after">{{ b.after }}</span>
        </div>
      </div>
      {% endfor %}

      <div class="camp-card camp-gift">
        <span class="camp-no">特典<strong>{{ site.cta.gift.no }}</strong></span>
        <div class="camp-gift-body">
          {% if site.cta.gift.image %}
          <div class="camp-gift-img"><img src="{{ site.cta.gift.image }}" alt="体組成計レポート見本" loading="lazy" decoding="async"></div>
          {% endif %}
          <div class="camp-gift-text">
            <div class="camp-gift-lead">{{ site.cta.gift.lead }}</div>
            <h3 class="camp-gift-title">{{ site.cta.gift.title }}</h3>
            <ul class="camp-gift-list">
              {% for g in site.cta.gift.items %}
              <li>{{ g | safe }}</li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="camp-foot">
      <div class="camp-limit">先着順！今月の体験予約枠 残り{{ site.campaign.remaining }}名様</div>
      <a href="#reserve" class="camp-btn">
        <span class="camp-btn-tag">手ぶらOK</span>
        <span class="camp-btn-main">無料体験を予約する</span>
        <span class="camp-btn-arr">→</span>
      </a>
      <p class="camp-note">{{ site.cta.note }}</p>
      <div class="camp-scroll">{{ site.cta.scroll }} ↓</div>
    </div>
  </div>
</section>

<!-- ─── RESERVATION (hacomono) ─── -->
<section class="sec-white" id="reserve">
  <div class="sec-content rv" style="padding-top: clamp(36px, 5vw, 60px);">
    <div class="reserve-widget">
      <iframe id="hacomono-widget-w0002" src="https://zennuwellnessdesign.hacomono.jp/widgets/2?isFilterableByCategory=false&isShowStudioInfo=true&studioIds=1" title="ZenNu 予約ウィジェット"></iframe>
    </div>
  </div>
</section>
<script src="https://zennuwellnessdesign.hacomono.jp/js/widget.js"></script>

