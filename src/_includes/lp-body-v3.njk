    .v3-plan a { display: block; margin-top: auto; padding: 15px; background: var(--v3-orange); color: #fff; font-size: 12px; font-weight: 900; text-align: center; }
    .v3-tickets { margin-top: 30px; padding: 28px; background: var(--v3-aqua); }
