    .v3-solution-slider { position: relative; }
    .v3-solution-grid { display: flex; gap: 24px; overflow-x: auto; padding: 6px max(15%,calc((100% - 760px)/2)) 18px; scroll-behavior: smooth; scroll-snap-type: x mandatory; scrollbar-width: none; }
