    .v3-trainer { position: relative; background: #e8f1f4; color: var(--v3-navy); }
    .v3-trainer::before { content: ""; position: absolute; inset: 0 0 auto; height: 360px; background: linear-gradient(rgba(11,35,57,.7),rgba(11,35,57,.83)),url('/images/personal2.jpg') center/cover; }
    .v3-trainer .v3-inner { position: relative; }
