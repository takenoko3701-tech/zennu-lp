    .v3-voice-result span { display: block; color: var(--v3-muted); font-size: 8px; }
    .v3-voice-result strong { color: #2bb39e; font-family: "Montserrat",sans-serif; font-size: 24px; }
    .v3-voice-result i { font-family: "Noto Sans JP",sans-serif; font-size: 9px; font-style: normal; }
    .v3-voice-route { margin-top: 17px; padding-left: 18px; color: var(--v3-muted); font-size: 10px; line-height: 1.8; }
    .v3-voice-route li + li { margin-top: 3px; }
    .v3-voice-now { margin-top: 16px; padding: 12px; background: #f2faf8; color: var(--v3-navy); font-size: 10px; font-weight: 700; line-height: 1.7; }

    .v3-flow { position: relative; background: #e8f2f4; }
    .v3-flow::before { content: ""; position: absolute; inset: 0 0 auto; height: 470px; background: linear-gradient(rgba(12,35,57,.62),rgba(12,35,57,.78)),url('/images/personal3.jpg') center/cover; }
    .v3-flow .v3-inner { position: relative; }
    .v3-flow .v3-heading h2 { color: #fff; }
    .v3-flow .v3-heading p,.v3-flow .v3-lead { color: rgba(255,255,255,.8); }
    .v3-flow-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 64px; }
    .v3-flow-step { position: relative; min-height: 580px; padding: 32px; border-radius: 22px; background: #fff; box-shadow: 0 14px 36px rgba(25,59,77,.1); }
    .v3-flow-step img { width: 100%; aspect-ratio: 1.45/1; border-radius: 14px; object-fit: cover; }
    .v3-flow-step span { position: absolute; z-index: 2; top: 14px; right: 28px; background: var(--v3-grad); -webkit-background-clip: text; background-clip: text; color: transparent; font-family: "Montserrat",sans-serif; font-size: 76px; font-weight: 500; line-height: 1; }
    .v3-flow-step h3 { margin-top: 25px; padding-bottom: 15px; border-bottom: 1px solid var(--v3-line); color: var(--v3-navy); font-size: 25px; }
    .v3-flow-step p { margin-top: 18px; color: var(--v3-muted); font-size: 12px; line-height: 2; }

    .v3-faq { background: var(--v3-aqua); }
    .v3-faq-list { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .v3-faq-item { overflow: hidden; background: #fff; }
    .v3-faq-q { display: grid; grid-template-columns: 36px 1fr 20px; align-items: center; gap: 10px; width: 100%; padding: 19px; cursor: pointer; text-align: left; }
    .v3-faq-mark { color: #37b7a4; font-family: "Montserrat",sans-serif; font-size: 22px; font-weight: 700; }
    .v3-faq-q strong { color: var(--v3-navy); font-size: 12px; }
    .v3-faq-icon { font-size: 20px; transition: transform .2s; }
    .v3-faq-a { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .25s; }
    .v3-faq-a > div { overflow: hidden; }
    .v3-faq-a p { padding: 0 19px 20px 65px; color: var(--v3-muted); font-size: 10px; line-height: 1.9; }
    .v3-faq-item.is-open .v3-faq-a { grid-template-rows: 1fr; }
    .v3-faq-item.is-open .v3-faq-icon { transform: rotate(45deg); }

    .v3-final { position: relative; overflow: hidden; padding: 98px var(--v3-pad); background: var(--v3-navy-deep); color: #fff; text-align: center; }
    .v3-final-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
    .v3-final::before { content: ""; position: absolute; z-index: 1; inset: 0; background: linear-gradient(rgba(11,25,45,.74),rgba(11,25,45,.92)); }
    .v3-final-inner { position: relative; z-index: 2; width: min(850px,100%); margin: auto; }
    .v3-final-label { display: inline-block; padding: 8px 20px; background: var(--v3-grad); font-size: 11px; font-weight: 900; letter-spacing: .12em; }
    .v3-final h2 { margin-top: 20px; font-size: clamp(34px,5vw,58px); font-weight: 500; line-height: 1.5; }
    .v3-final h2 strong { font-weight: 900; }
    .v3-final p { margin: 20px 0 28px; color: rgba(255,255,255,.76); font-size: 13px; line-height: 2; }
    .v3-final .v3-offer-btn { width: min(610px,100%); margin: auto; }
    .v3-final-limit { margin-top: 18px; color: #fff28d; font-size: 11px; font-weight: 800; }

    .v3-reserve { padding: 62px 20px 90px; background: #f4f8f9; }
    .v3-reserve-inner { width: min(930px,100%); margin: auto; }
    .v3-reserve-heading { margin-bottom: 25px; text-align: center; }
    .v3-reserve-heading span { color: #3bb8a5; font-family: "Montserrat",sans-serif; font-size: 11px; letter-spacing: .22em; }
    .v3-reserve-heading h2 { margin-top: 6px; color: var(--v3-navy); font-size: 27px; }
    .v3-reserve-widget { overflow: hidden; background: #fff; border: 1px solid var(--v3-line); }
    .v3-reserve-widget iframe { width: 100%; min-height: 680px; border: 0; }

    .v3-access { padding: 86px var(--v3-pad); background: #fff; }
    .v3-access-grid { display: grid; grid-template-columns: 1.08fr .92fr; overflow: hidden; border: 1px solid var(--v3-line); background: var(--v3-aqua); }
    .v3-access-map iframe { display: block; width: 100%; height: 100%; min-height: 500px; border: 0; filter: saturate(.72); }
    .v3-access-info { padding: 36px; }
    .v3-access-row { display: grid; grid-template-columns: 92px 1fr; gap: 18px; padding: 15px 0; border-bottom: 1px solid #cbdcdf; color: var(--v3-ink); font-size: 11px; line-height: 1.8; }
    .v3-access-row:first-child { padding-top: 0; }
    .v3-access-row dt { color: #3aafa3; font-family: "Montserrat",sans-serif; font-size: 10px; font-weight: 800; letter-spacing: .08em; }
    .v3-access-row dd { font-style: normal; }
    .v3-access-row strong { margin-left: 5px; color: var(--v3-navy); }
    .v3-access-row .info-note { display: block; margin-top: 3px; color: var(--v3-muted); font-size: 9px; }
    .v3-contact-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 24px; }
    .v3-contact-btn { display: flex; align-items: center; justify-content: center; min-height: 64px; padding: 14px; color: #fff; font-size: 12px; font-weight: 900; text-align: center; }
    .v3-contact-btn.is-line { background: #06c755; }
    .v3-contact-btn.is-tel { background: var(--v3-navy); }
    .v3-contact-btn small { display: block; margin-bottom: 2px; color: rgba(255,255,255,.72); font-size: 8px; font-weight: 600; }

    .v3-footer { padding: 44px var(--v3-pad) 100px; background: var(--v3-navy-deep); color: #fff; }
    .v3-footer-inner { display: grid; grid-template-columns: 1fr auto; align-items: end; gap: 34px; width: min(var(--v3-max),100%); margin: auto; }
    .v3-footer-brand img { width: 230px; filter: brightness(0) invert(1); }
    .v3-footer-brand p { margin-top: 14px; color: rgba(255,255,255,.65); font-size: 11px; line-height: 1.8; }
    .v3-footer-links { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 12px 18px; color: rgba(255,255,255,.58); font-size: 9px; }
    .v3-footer-links a:hover { color: #fff; }
    .v3-footer-copy { grid-column: 1/-1; padding-top: 18px; border-top: 1px solid rgba(255,255,255,.13); color: rgba(255,255,255,.42); font-size: 8px; text-align: right; }

    .v3-sticky { position: fixed; z-index: 99; left: 0; right: 0; bottom: 0; transition: transform .25s; }
    .v3-sticky.is-hidden { transform: translateY(110%); }
    .v3-sticky-inner { display: grid; grid-template-columns: 1fr 1.18fr; align-items: center; min-height: 64px; background: var(--v3-grad); color: #fff; }
    .v3-sticky-copy { padding: 11px 28px; font-size: 13px; font-weight: 700; text-align: right; letter-spacing: .1em; }
    .v3-sticky a { display: flex; align-items: center; justify-content: center; gap: 15px; align-self: stretch; background: var(--v3-orange); font-size: 14px; font-weight: 900; }
    .v3-sticky a strong { color: #fff28d; }

    @media (max-width: 900px) {
      .v3-header-copy { display: none; }
      .v3-hero-media { inset: 72px 0 0; grid-template-columns: 1fr; opacity: .52; }
      .v3-hero-main { clip-path: none; margin: 0; }
      .v3-hero-side { display: none; }
      .v3-hero::before { background: linear-gradient(90deg,rgba(11,25,45,.96),rgba(11,25,45,.7)); }
      .v3-hero-copy { width: min(650px,86%); }
      .v3-offer-inner { grid-template-columns: 1fr; gap: 18px; }
      .v3-intro-grid { grid-template-columns: 1fr; }
      .v3-wants-grid { grid-template-columns: repeat(2,1fr); }
