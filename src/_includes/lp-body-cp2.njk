    .v3-ticket-head p { margin-top: 5px; color: rgba(255,255,255,.72); font-size: 9px; }
    .v3-ticket-body { display: flex; flex: 1; flex-direction: column; padding: 24px 26px; }
    .v3-ticket-price { color: #2fb9ad; font-family: "Montserrat",sans-serif; font-size: 39px; font-weight: 800; }
    .v3-ticket-price span { margin-left: 3px; color: var(--v3-muted); font-family: "Noto Sans JP",sans-serif; font-size: 10px; }
    .v3-ticket-items { margin: 18px 0; border-top: 1px solid var(--v3-line); }
    .v3-ticket-item { position: relative; padding: 11px 0 11px 22px; border-bottom: 1px solid var(--v3-line); font-size: 10px; }
    .v3-ticket-item::before { content: "✓"; position: absolute; left: 0; color: #35b89f; font-weight: 900; }
